---
/**
 * Toggle Component - Collapsible content with smooth animation
 *
 * Usage in .astro files:
 *   <Toggle title="Click to expand">
 *     Content goes here
 *   </Toggle>
 */

interface Props {
  title: string;
  open?: boolean;
}

const { title, open = false } = Astro.props;
---

<div class="toggle-container" data-open={open}>
  <button class="toggle-header" aria-expanded={open}>
    <span class="toggle-icon"></span>
    <span class="toggle-title">{title}</span>
  </button>
  <div class="toggle-wrapper">
    <div class="toggle-inner">
      <div class="toggle-content">
        <slot />
      </div>
    </div>
  </div>
</div>

<script>
  // Handle toggle logic using event delegation (works even if buttons added later)
  document.addEventListener('click', (e) => {
    const button = (e.target as HTMLElement).closest('.toggle-header');
    if (!button) return;

    const container = button.closest('.toggle-container');
    const isOpen = container?.getAttribute('data-open') === 'true';

    // Toggle state
    container?.setAttribute('data-open', (!isOpen).toString());
    button.setAttribute('aria-expanded', (!isOpen).toString());
  });
</script>

<style>
  .toggle-container {
    margin: 0.15rem 0;
    border-radius: 6px;
    background: transparent;
    overflow: hidden;
    transition: background 0.15s ease;
  }
  .toggle-container:hover {
    background: var(--color-surface-hover, rgba(255, 255, 255, 0.03));
  }
  .toggle-container[data-open='true'] {
    background: var(--color-surface);
  }

  .toggle-header {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.65rem;
    width: 100%;
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    text-align: left;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s ease;
  }
  .toggle-header:hover {
    color: var(--color-accent);
  }

  .toggle-icon {
    width: 0;
    height: 0;
    border-left: 5px solid var(--color-accent);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    transition: transform 0.2s ease;
    flex-shrink: 0;
    opacity: 0.7;
  }

  /* Rotate icon when open */
  .toggle-container[data-open='true'] .toggle-icon {
    transform: rotate(90deg);
    opacity: 1;
  }

  .toggle-title {
    flex: 1;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* The Animation Magic: Grid Template Rows */
  .toggle-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .toggle-container[data-open='true'] .toggle-wrapper {
    grid-template-rows: 1fr;
  }

  .toggle-inner {
    overflow: hidden;
  }

  .toggle-content {
    padding: 0.25rem 0.65rem 0.75rem 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
    min-height: 0;
  }

  .toggle-content :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Touch-friendly sizing */
  @media (pointer: coarse) {
    .toggle-header {
      padding: 0.6rem 0.65rem;
      min-height: 40px;
    }
  }
</style>
