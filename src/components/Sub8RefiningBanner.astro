---
/**
 * Sub8RefiningBanner — shown on posts whose tribunal composite is below the
 * featured bar (<8). It is NOT an error: the post ships at its own URL and
 * shows its real AI-judge scores, but is held off the homepage until a
 * background tribunal rewrites it up to >=8.
 * Spec: openspec/specs/publish-bar-visibility/spec.md; 人話摘要見
 * CONTRIBUTING.md §兩層品質門檻.
 */

interface Props {
  composite: number; // overall tribunal composite, 0-10
  lang?: 'zh-tw' | 'en';
}

const { composite, lang = 'zh-tw' } = Astro.props;

const labels = {
  'zh-tw': {
    title: '這篇還在精修中',
    body: `tribunal 給的分數還沒到 gu-log 的 featured 門檻（≥8），所以暫時不上首頁。背景 tribunal 之後會把它重寫拉高，分數過了就自動上架。`,
    scoreLabel: '目前綜合分數',
    cta: '下面是 AI judge 目前打的分數，覺得哪裡可以更好？留言告訴我們 (>w<)',
  },
  en: {
    title: 'This article is still being refined',
    body: `Its tribunal score has not yet reached gu-log's featured bar (>=8), so it is kept off the homepage for now. A background tribunal will rewrite it upward, and it goes live once it clears the bar.`,
    scoreLabel: 'Current composite',
    cta: 'The AI-judge scores below are where it stands now. See a way to make it better? Drop a comment (>w<)',
  },
} as const;

const t = labels[lang];
---

<details class="sub8-refining-banner">
  <summary class="banner-header">
    <span class="banner-icon" aria-hidden="true">
      <svg
        viewBox="0 0 24 24"
        width="17"
        height="17"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 3a9 9 0 1 0 9 9"></path>
        <path d="M12 7v5l3 2"></path>
        <path d="M17 3h4v4"></path>
        <path d="m21 3-5 5"></path>
      </svg>
    </span>
    <span class="banner-title">{t.title}</span>
    <span class="banner-score" aria-label={t.scoreLabel}>{t.scoreLabel}: {composite}/10</span>
    <span class="banner-chevron" aria-hidden="true">
      <svg
        viewBox="0 0 24 24"
        width="16"
        height="16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m8 10 4 4 4-4"></path>
      </svg>
    </span>
  </summary>
  <div class="banner-body">
    <p class="banner-text">{t.body}</p>
    <p class="banner-cta">{t.cta}</p>
  </div>
</details>

<style>
  .sub8-refining-banner {
    margin: 1rem 0 1.5rem;
    border-left: 2px solid var(--color-accent);
  }

  .banner-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 0.45rem;
    min-height: 44px;
    padding: 0.45rem 0.65rem;
    color: var(--color-accent);
    cursor: pointer;
    list-style: none;
  }

  .banner-header::-webkit-details-marker {
    display: none;
  }

  .banner-header:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .banner-icon,
  .banner-chevron {
    display: inline-flex;
  }

  .banner-title {
    overflow: hidden;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .banner-score {
    font-size: 0.76rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .banner-chevron {
    transition: transform 160ms ease;
  }

  .sub8-refining-banner[open] .banner-chevron {
    transform: rotate(180deg);
  }

  .banner-body {
    margin-left: 0.65rem;
    padding: 0.65rem 0.65rem 0.8rem;
    border-top: 1px solid var(--color-divider);
  }

  .banner-text {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .banner-cta {
    margin: 0;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .banner-score {
      max-width: 8.2rem;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }
</style>
