---
/**
 * TicketBadge - Display article ticket ID with appropriate styling
 *
 * Types:
 * - SD: ShroomDog Original (accent color)
 * - SP: Gu-log Picks (muted color) — stored as SP- slug, displayed as GP-
 * - CP: Mogu Picks (mogu color)
 * - Lv: Level-Up (purple)
 */
interface Props {
  ticketId: string;
  showTooltip?: boolean;
  showLabel?: boolean;
}

const { ticketId, showTooltip = true, showLabel = false } = Astro.props;

// Extract prefix (SD, SP, CP)
const prefix = ticketId.split('-')[0];

const labels: Record<string, string> = {
  SD: 'ShroomDog Original',
  SP: 'Gu-log Picks',
  CP: 'Mogu Picks',
  Lv: 'Level-Up',
};

// Display alias: the SP series is branded "Gu-log Picks" with a GP- ticket,
// and the CP series is branded "Mogu Picks" with an MP- ticket, while the
// underlying slug/URL/ticketId stays SP-/CP- (no URL breakage).
const displayId = ticketId.replace(/^SP-/, 'GP-').replace(/^CP-/, 'MP-');

const label = labels[prefix] || '';
---

<span class="ticket-wrapper">
  <span
    class={`ticket-badge ticket-${prefix.toLowerCase()}`}
    title={showTooltip && !showLabel ? label : undefined}
  >
    {displayId}
  </span>
  {showLabel && <span class={`ticket-label ticket-label-${prefix.toLowerCase()}`}>{label}</span>}
</span>

<style>
  .ticket-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ticket-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.03em;
    vertical-align: middle;
    cursor: default;
    transition: opacity 0.2s ease;
  }

  .ticket-badge:hover {
    opacity: 0.8;
  }

  .ticket-label {
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* SD: ShroomDog Original - muted green/teal */
  .ticket-sd {
    background-color: rgba(38, 139, 121, 0.15);
    color: var(--color-badge-sd);
    border: 1px solid transparent;
  }

  .ticket-label-sd {
    color: var(--color-badge-sd);
  }

  /* SP: ShroomDog Picks - muted blue */
  .ticket-sp {
    background-color: rgba(38, 139, 210, 0.15);
    color: var(--color-badge-sp);
    border: 1px solid transparent;
  }

  .ticket-label-sp {
    color: var(--color-badge-sp);
  }

  /* CP: Mogu Picks - muted orange */
  .ticket-cp {
    background-color: rgba(203, 117, 81, 0.15);
    color: var(--color-badge-cp);
    border: 1px solid transparent;
  }

  .ticket-label-cp {
    color: var(--color-badge-cp);
  }

  /* Lv: Level-Up - muted purple */
  .ticket-lv {
    background-color: rgba(136, 97, 203, 0.15);
    color: var(--color-badge-lv);
    border: 1px solid transparent;
  }

  .ticket-label-lv {
    color: var(--color-badge-lv);
  }

  /* Light mode: badges need visible borders on cream bg */
  :global([data-theme='light']) .ticket-sd {
    background-color: rgba(29, 106, 92, 0.12);
    border-color: rgba(29, 106, 92, 0.35);
  }
  :global([data-theme='light']) .ticket-sp {
    background-color: rgba(25, 93, 140, 0.12);
    border-color: rgba(25, 93, 140, 0.35);
  }
  :global([data-theme='light']) .ticket-cp {
    background-color: rgba(133, 77, 53, 0.12);
    border-color: rgba(133, 77, 53, 0.35);
  }
  :global([data-theme='light']) .ticket-lv {
    background-color: rgba(107, 76, 160, 0.12);
    border-color: rgba(107, 76, 160, 0.35);
  }
</style>
