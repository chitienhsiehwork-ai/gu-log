---
/**
 * AiJudgeScore — Tribunal Quality Panel
 *
 * 4 judges, uniform 0-10 scale, new dimension map:
 *   Librarian (Opus 4.7)    → glossary · crossRef · sourceAlign · attribution
 *   Fact Check (GPT-5.5)    → accuracy · fidelity · consistency · sourceBoundary · commentarySeparation
 *   Fresh Eyes (GPT-5.5)    → readability · firstImpression · payoffDensity · lengthFit · clarity (v9+)
 *   Vibe (Opus 4.6[1m])     → persona · moguNote · vibe · narrative (v9; legacy v8 also clarity)
 *
 * clarity ownership is version-aware (move-clarity-vibe-to-fresheyes): v9+ posts
 * carry it under freshEyes, v8 posts under vibe. Per-dimension `!== undefined`
 * guards render it wherever it lives, so both shapes display correctly.
 *
 * Scores live in post frontmatter. No legacy keys (ralph/gemini/codex/sonnet).
 */

interface Props {
  scores?: {
    tribunalVersion?: number;
    librarian?: {
      glossary?: number;
      crossRef?: number;
      sourceAlign?: number;
      attribution?: number;
      score: number;
      date: string;
      model?: string;
    };
    factCheck?: {
      accuracy?: number;
      fidelity?: number;
      consistency?: number;
      sourceBoundary?: number;
      commentarySeparation?: number;
      score: number;
      date: string;
      model?: string;
    };
    freshEyes?: {
      readability?: number;
      firstImpression?: number;
      payoffDensity?: number;
      lengthFit?: number;
      // tribunalVersion >= 9: clarity moved from vibe → freshEyes.
      clarity?: number;
      score: number;
      date: string;
      model?: string;
    };
    vibe?: {
      persona?: number;
      moguNote?: number;
      vibe?: number;
      clarity?: number;
      narrative?: number;
      score: number;
      date: string;
      model?: string;
    };
    // ShroomDog's own vibe — the named human editor, set apart from the AI tribunal.
    shroomDogVibe?: {
      score: number;
      date: string;
      note?: string;
    };
  };
  lang?: string;
}

const { scores } = Astro.props;

const hasScores =
  scores &&
  (scores.librarian || scores.factCheck || scores.freshEyes || scores.vibe || scores.shroomDogVibe);

const labelsLang = Astro.props.lang === 'en' ? 'en' : 'zh-tw';
const sdStrings =
  labelsLang === 'en'
    ? { name: 'ShroomDog Vibe', sub: 'human editor · the author himself' }
    : { name: 'ShroomDog 私心評分', sub: '本人手評 · 非 AI 法官' };

const tribunalVersion = scores?.tribunalVersion ?? 3;

function scoreColor(score: number): string {
  if (score >= 9) return 'score-high';
  if (score >= 8) return 'score-pass';
  return 'score-fail';
}

const labels = {
  librarian: 'Librarian',
  factCheck: 'Fact Check',
  freshEyes: 'Fresh Eyes',
  vibe: 'Vibe',
  glossary: 'Glossary',
  crossRef: 'CrossRef',
  sourceAlign: 'SourceAlign',
  attribution: 'Attribution',
  accuracy: 'Accuracy',
  fidelity: 'Fidelity',
  consistency: 'Consistency',
  sourceBoundary: 'Boundary',
  commentarySeparation: 'Separation',
  readability: 'Readability',
  firstImpression: 'FirstImpression',
  payoffDensity: 'PayoffDensity',
  lengthFit: 'LengthFit',
  persona: 'Persona',
  moguNote: 'MoguNote',
  vibe_dim: 'Vibe',
  clarity: 'Clarity',
  narrative: 'Narrative',
};
---

{
  hasScores && (
    <div class="ai-judge-panel">
      <div class="judge-header">
        <span class="judge-title">
          <svg
            viewBox="0 0 24 24"
            width="17"
            height="17"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 21h18" />
            <path d="M5 21V9" />
            <path d="M19 21V9" />
            <path d="M9 21V9" />
            <path d="M15 21V9" />
            <path d="m3 9 9-6 9 6Z" />
          </svg>
          Tribunal Scores
        </span>
        <span class="tribunal-version">v{tribunalVersion}</span>
      </div>

      <div class="judge-cards">
        {scores?.librarian && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-librarian">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-librarian">{labels.librarian}</span>
                {scores.librarian.model && <span class="model-info">{scores.librarian.model}</span>}
              </div>
            </div>
            <div class={`card-score ${scoreColor(scores.librarian.score)}`}>
              {scores.librarian.score}
              <span class="score-denom">/10</span>
            </div>
            <div class="dim-list">
              {scores.librarian.glossary !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Gloss">
                    {labels.glossary}
                  </span>
                  <strong class={scoreColor(scores.librarian.glossary)}>
                    {scores.librarian.glossary}
                  </strong>
                </span>
              )}
              {scores.librarian.crossRef !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="XRef">
                    {labels.crossRef}
                  </span>
                  <strong class={scoreColor(scores.librarian.crossRef)}>
                    {scores.librarian.crossRef}
                  </strong>
                </span>
              )}
              {scores.librarian.sourceAlign !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Src">
                    {labels.sourceAlign}
                  </span>
                  <strong class={scoreColor(scores.librarian.sourceAlign)}>
                    {scores.librarian.sourceAlign}
                  </strong>
                </span>
              )}
              {scores.librarian.attribution !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Attr">
                    {labels.attribution}
                  </span>
                  <strong class={scoreColor(scores.librarian.attribution)}>
                    {scores.librarian.attribution}
                  </strong>
                </span>
              )}
            </div>
          </div>
        )}

        {scores?.freshEyes && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-fresheyes">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-fresheyes">{labels.freshEyes}</span>
                {scores.freshEyes.model && <span class="model-info">{scores.freshEyes.model}</span>}
              </div>
            </div>
            <div class={`card-score ${scoreColor(scores.freshEyes.score)}`}>
              {scores.freshEyes.score}
              <span class="score-denom">/10</span>
            </div>
            <div class="dim-list">
              {scores.freshEyes.readability !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Read">
                    {labels.readability}
                  </span>
                  <strong class={scoreColor(scores.freshEyes.readability)}>
                    {scores.freshEyes.readability}
                  </strong>
                </span>
              )}
              {scores.freshEyes.firstImpression !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="First">
                    {labels.firstImpression}
                  </span>
                  <strong class={scoreColor(scores.freshEyes.firstImpression)}>
                    {scores.freshEyes.firstImpression}
                  </strong>
                </span>
              )}
              {scores.freshEyes.payoffDensity !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Payoff">
                    {labels.payoffDensity}
                  </span>
                  <strong class={scoreColor(scores.freshEyes.payoffDensity)}>
                    {scores.freshEyes.payoffDensity}
                  </strong>
                </span>
              )}
              {scores.freshEyes.lengthFit !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Length">
                    {labels.lengthFit}
                  </span>
                  <strong class={scoreColor(scores.freshEyes.lengthFit)}>
                    {scores.freshEyes.lengthFit}
                  </strong>
                </span>
              )}
              {scores.freshEyes.clarity !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Clarity">
                    {labels.clarity}
                  </span>
                  <strong class={scoreColor(scores.freshEyes.clarity)}>
                    {scores.freshEyes.clarity}
                  </strong>
                </span>
              )}
            </div>
          </div>
        )}

        {scores?.factCheck && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-factcheck">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-factcheck">{labels.factCheck}</span>
                {scores.factCheck.model && <span class="model-info">{scores.factCheck.model}</span>}
              </div>
            </div>
            <div class={`card-score ${scoreColor(scores.factCheck.score)}`}>
              {scores.factCheck.score}
              <span class="score-denom">/10</span>
            </div>
            <div class="dim-list">
              {scores.factCheck.accuracy !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Acc">
                    {labels.accuracy}
                  </span>
                  <strong class={scoreColor(scores.factCheck.accuracy)}>
                    {scores.factCheck.accuracy}
                  </strong>
                </span>
              )}
              {scores.factCheck.fidelity !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Fid">
                    {labels.fidelity}
                  </span>
                  <strong class={scoreColor(scores.factCheck.fidelity)}>
                    {scores.factCheck.fidelity}
                  </strong>
                </span>
              )}
              {scores.factCheck.consistency !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Cons">
                    {labels.consistency}
                  </span>
                  <strong class={scoreColor(scores.factCheck.consistency)}>
                    {scores.factCheck.consistency}
                  </strong>
                </span>
              )}
              {scores.factCheck.sourceBoundary !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Bound">
                    {labels.sourceBoundary}
                  </span>
                  <strong class={scoreColor(scores.factCheck.sourceBoundary)}>
                    {scores.factCheck.sourceBoundary}
                  </strong>
                </span>
              )}
              {scores.factCheck.commentarySeparation !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Sep">
                    {labels.commentarySeparation}
                  </span>
                  <strong class={scoreColor(scores.factCheck.commentarySeparation)}>
                    {scores.factCheck.commentarySeparation}
                  </strong>
                </span>
              )}
            </div>
          </div>
        )}

        {scores?.vibe && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-vibe">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 13 C4 13, 5.5 7, 7 6.5 C8.5 6, 8.5 20, 10.5 20.5 C12.5 21, 12 2.5, 14 2 C16 1.5, 16 15, 18 15.5 C20 16, 21 12.5, 22 12" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-vibe">{labels.vibe}</span>
                {scores.vibe.model && <span class="model-info">{scores.vibe.model}</span>}
              </div>
            </div>
            <div class={`card-score ${scoreColor(scores.vibe.score)}`}>
              {scores.vibe.score}
              <span class="score-denom">/10</span>
            </div>
            <div class="dim-list">
              {scores.vibe.persona !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Pers">
                    {labels.persona}
                  </span>
                  <strong class={scoreColor(scores.vibe.persona)}>{scores.vibe.persona}</strong>
                </span>
              )}
              {scores.vibe.moguNote !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Note">
                    {labels.moguNote}
                  </span>
                  <strong class={scoreColor(scores.vibe.moguNote)}>{scores.vibe.moguNote}</strong>
                </span>
              )}
              {scores.vibe.vibe !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Vibe">
                    {labels.vibe_dim}
                  </span>
                  <strong class={scoreColor(scores.vibe.vibe)}>{scores.vibe.vibe}</strong>
                </span>
              )}
              {scores.vibe.clarity !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Clear">
                    {labels.clarity}
                  </span>
                  <strong class={scoreColor(scores.vibe.clarity)}>{scores.vibe.clarity}</strong>
                </span>
              )}
              {scores.vibe.narrative !== undefined && (
                <span class="dim-item">
                  <span class="dim-label" data-short="Narr">
                    {labels.narrative}
                  </span>
                  <strong class={scoreColor(scores.vibe.narrative)}>{scores.vibe.narrative}</strong>
                </span>
              )}
            </div>
          </div>
        )}
      </div>

      {scores?.shroomDogVibe && (
        <div class="shroomdog-vibe">
          <img class="sd-icon" src="/shroomdog-icon-128.png" alt="" />
          <div class="sd-body">
            <div class="sd-top">
              <div class="sd-meta">
                <span class="sd-name">{sdStrings.name}</span>
                <span class="sd-sub">{sdStrings.sub}</span>
              </div>
              <div class={`sd-score ${scoreColor(scores.shroomDogVibe.score)}`}>
                {scores.shroomDogVibe.score}
                <span class="score-denom">/10</span>
              </div>
            </div>
            {scores.shroomDogVibe.note && <p class="sd-note">{scores.shroomDogVibe.note}</p>}
          </div>
        </div>
      )}
    </div>
  )
}

<style>
  .ai-judge-panel {
    margin-top: 2rem;
    padding: 1rem;
    background-color: var(--color-panel-subtle);
    border-radius: 8px;
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    text-align: left;
  }

  .judge-header {
    margin-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    text-align: left;
  }

  .judge-title {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-surface-meta);
  }

  .tribunal-version {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .judge-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 639px) {
    .judge-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 339px) {
    .judge-cards {
      grid-template-columns: 1fr;
    }
  }

  .judge-card {
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-start;
    min-width: 0;
    text-align: left;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    justify-content: flex-start;
    min-width: 0;
    text-align: left;
  }

  .judge-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    min-width: 0;
    align-items: flex-start;
    text-align: left;
  }

  .judge-name {
    font-weight: 600;
    font-size: 0.85rem;
    line-height: 1.2;
  }

  .card-score {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
    margin: 0.1rem 0;
    width: 100%;
    text-align: left;
  }

  .score-denom {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .model-info {
    font-size: 0.65rem;
    color: var(--color-technical-model);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Score value colors */
  .score-high {
    color: var(--color-status-success);
  }
  .score-pass {
    color: var(--color-status-success);
  }
  .score-fail {
    color: var(--color-status-danger);
  }

  /* Judge brand colors */
  .judge-color-librarian {
    color: var(--color-judge-librarian);
  }
  .judge-color-factcheck {
    color: var(--color-judge-factcheck);
  }
  .judge-color-fresheyes {
    color: var(--color-judge-fresheyes);
  }
  .judge-color-vibe {
    color: var(--color-judge-vibe);
  }

  .dim-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.18rem;
    align-items: start;
    justify-items: start;
    color: var(--color-text-muted);
    font-size: 0.7rem;
    margin-top: 0.1rem;
    width: 100%;
    min-width: 0;
    text-align: left;
  }

  .dim-item {
    display: flex;
    gap: 0.35rem;
    align-items: baseline;
    justify-content: flex-start;
    width: 100%;
    min-width: 0;
  }

  .dim-label {
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }

  .dim-item strong {
    font-weight: 600;
    font-size: 0.75rem;
  }

  /* ShroomDog's own score — human editor, deliberately set apart from the AI grid */
  .shroomdog-vibe {
    margin-top: 0.75rem;
    padding: 0.75rem;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-status-warning);
    border-radius: 6px;
    background-color: var(--color-panel-subtle);
    text-align: left;
  }

  .sd-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
  }

  .sd-body {
    flex: 1;
    min-width: 0;
  }

  .sd-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
  }

  .sd-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .sd-name {
    font-weight: 600;
    font-size: 0.85rem;
    line-height: 1.2;
    color: var(--color-status-warning);
  }

  .sd-sub {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    line-height: 1.2;
  }

  .sd-score {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
  }

  .sd-note {
    margin: 0.4rem 0 0;
    font-size: 0.72rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .ai-judge-panel {
      padding: 0.875rem;
    }

    .judge-cards {
      gap: 0.5rem;
    }

    .judge-card {
      padding: 0.625rem;
      gap: 0.35rem;
    }

    .card-header {
      gap: 0.35rem;
    }

    .judge-icon svg {
      width: 18px;
      height: 18px;
    }

    .judge-name {
      font-size: 0.78rem;
    }

    .model-info {
      max-width: 100%;
      font-size: 0.6rem;
    }

    .card-score {
      font-size: 1.35rem;
    }

    .dim-list {
      gap: 0.14rem;
    }

    .dim-item {
      gap: 0.16rem;
    }

    .dim-label {
      font-size: 0;
    }

    .dim-label::after {
      content: attr(data-short);
      font-size: 0.62rem;
    }
  }
</style>
