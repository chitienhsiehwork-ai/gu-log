---
/**
 * AiJudgeScore — Shows AI quality scores for a post
 *
 * 🔵 Claude  → Vibe (3 sub-scores: persona/clawdNote/vibe)
 * 🟢 Codex   → Fact Check (single 0-10 score)
 * 🔴 Gemini  → Source Verification (single 0-10 score)
 */

interface Props {
  ticketId: string;
  vibeScores?: { persona: number; clawdNote: number; vibe: number };
  factCheckScore?: number;
  crossRefScore?: number;
  lang?: string;
}

const {
  ticketId: _ticketId,
  vibeScores,
  factCheckScore,
  crossRefScore,
  lang = 'zh-tw',
} = Astro.props;

const REPO_BASE = 'https://github.com/chitienhsiehwork-ai/gu-log/blob/main';
const hasScores = vibeScores || factCheckScore != null || crossRefScore != null;

const vibeComposite = vibeScores
  ? Math.floor((vibeScores.persona + vibeScores.clawdNote + vibeScores.vibe) / 3)
  : null;

const title = lang === 'zh-tw' ? 'AI 評審團' : 'AI Judge Panel';
const scriptLink = `${REPO_BASE}/scripts/multi-scorer.sh`;
---

{
  hasScores && (
    <div class="ai-judge-panel">
      <div class="judge-header">
        <span class="judge-title">⚖️ {title}</span>
        <a href={scriptLink} target="_blank" rel="noopener" class="judge-link">
          {lang === 'zh-tw' ? '評分腳本 →' : 'Scoring script →'}
        </a>
      </div>

      <div class="judge-scores">
        {vibeScores && (
          <div class="judge-group">
            <div class="judge-label">
              <span>🔵 Claude</span>
              <a
                href={`${REPO_BASE}/scripts/prompts/vibe-scorer.md`}
                target="_blank"
                rel="noopener"
                class="judge-link"
              >
                {lang === 'zh-tw' ? '風格評審' : 'Vibe Judge'}
              </a>
            </div>
            <div class="vibe-details">
              <span class="vibe-dim">
                {lang === 'zh-tw' ? '人物感' : 'Persona'} <strong>{vibeScores.persona}</strong>
              </span>
              <span class="vibe-dim">
                ClawdNote <strong>{vibeScores.clawdNote}</strong>
              </span>
              <span class="vibe-dim">
                Vibe <strong>{vibeScores.vibe}</strong>
              </span>
              <span class="vibe-composite">
                = <strong>{vibeComposite}/10</strong>
              </span>
            </div>
          </div>
        )}

        {factCheckScore != null && (
          <div class="judge-row">
            <span class="judge-label">
              <span>🟢 Codex</span>
              <a
                href={`${REPO_BASE}/scripts/prompts/fact-checker.md`}
                target="_blank"
                rel="noopener"
                class="judge-link"
              >
                {lang === 'zh-tw' ? '事實查核' : 'Fact Check'}
              </a>
            </span>
            <strong class="single-score">{factCheckScore}/10</strong>
          </div>
        )}

        {crossRefScore != null && (
          <div class="judge-row">
            <span class="judge-label">
              <span>🔴 Gemini</span>
              <a
                href={`${REPO_BASE}/scripts/prompts/crossref-verifier.md`}
                target="_blank"
                rel="noopener"
                class="judge-link"
              >
                {lang === 'zh-tw' ? '來源驗證' : 'Source Check'}
              </a>
            </span>
            <strong class="single-score">{crossRefScore}/10</strong>
          </div>
        )}
      </div>
    </div>
  )
}

<style>
  .ai-judge-panel {
    margin-top: 2rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-bg-secondary, rgba(0, 0, 0, 0.03));
    border-radius: 8px;
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
  }

  .judge-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .judge-title {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .judge-link {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .judge-link:hover {
    color: var(--color-accent);
  }

  .judge-scores {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .judge-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .judge-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .judge-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .vibe-details {
    display: flex;
    gap: 0.75rem;
    padding-left: 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .vibe-dim strong,
  .vibe-composite strong {
    color: var(--color-text);
  }

  .single-score {
    font-size: 0.9rem;
  }
</style>
