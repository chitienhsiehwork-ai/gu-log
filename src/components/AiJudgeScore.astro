---
/**
 * AiJudgeScore — Ralph Tribunal: Shows AI quality scores for a post
 *
 * Curator (Gemini) → Source verification (scores.gemini)
 * Checker (Codex)  → Fact check (scores.codex)
 * Vibe (Opus)      → Style/persona (scores.ralph: p/c/v)
 *
 * Scores live in post frontmatter — no manifest lookup, no stale detection.
 */

interface Props {
  scores?: {
    ralph?: { p: number; c: number; v: number; date: string };
    gemini?: { score: number; date: string };
    codex?: { score: number; date: string };
  };
  lang?: string;
}

const { scores, lang = 'zh-tw' } = Astro.props;

const REPO_BASE = 'https://github.com/chitienhsiehwork-ai/gu-log/blob/main';
const hasScores = scores && (scores.ralph || scores.gemini != null || scores.codex != null);

const vibeScores = scores?.ralph
  ? { persona: scores.ralph.p, clawdNote: scores.ralph.c, vibe: scores.ralph.v }
  : null;

const vibeComposite = vibeScores
  ? Math.floor((vibeScores.persona + vibeScores.clawdNote + vibeScores.vibe) / 3)
  : null;

const crossRefScore = scores?.gemini?.score ?? null;
const factCheckScore = scores?.codex?.score ?? null;

const scriptLink = `${REPO_BASE}/scripts/ralph-orchestrator.sh`;

function scoreClass(_score: number): string {
  return 'score-neutral';
}
---

{
  hasScores && (
    <div class="ai-judge-panel">
      <div class="judge-header">
        <span class="judge-title">🏛️ Ralph Tribunal</span>
        <a href={scriptLink} target="_blank" rel="noopener" class="judge-link">
          {lang === 'zh-tw' ? '評分腳本 →' : 'Scoring script →'}
        </a>
      </div>

      <div class="judge-cards">
        {crossRefScore != null && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-curator">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                  <path d="M12 1l1 2 2 1-2 1-1 2-1-2-2-1 2-1z" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-curator">Curator</span>
                <a
                  href={`${REPO_BASE}/scripts/prompts/crossref-verifier.md`}
                  target="_blank"
                  rel="noopener"
                  class="judge-link"
                >
                  {lang === 'zh-tw' ? '來源驗證' : 'Source Check'}
                </a>
              </div>
            </div>
            <div class={`card-score ${scoreClass(crossRefScore)}`}>
              {crossRefScore}
              <span class="score-denom">/10</span>
            </div>
          </div>
        )}

        {factCheckScore != null && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-checker">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-checker">Checker</span>
                <a
                  href={`${REPO_BASE}/scripts/prompts/fact-checker.md`}
                  target="_blank"
                  rel="noopener"
                  class="judge-link"
                >
                  {lang === 'zh-tw' ? '事實查核' : 'Fact Check'}
                </a>
              </div>
            </div>
            <div class={`card-score ${scoreClass(factCheckScore)}`}>
              {factCheckScore}
              <span class="score-denom">/10</span>
            </div>
          </div>
        )}

        {vibeScores && vibeComposite != null && (
          <div class="judge-card">
            <div class="card-header">
              <span class="judge-icon judge-color-vibe">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 13 C4 13, 5.5 7, 7 6.5 C8.5 6, 8.5 20, 10.5 20.5 C12.5 21, 12 2.5, 14 2 C16 1.5, 16 15, 18 15.5 C20 16, 21 12.5, 22 12" />
                </svg>
              </span>
              <div class="card-meta">
                <span class="judge-name judge-color-vibe">Vibe</span>
                <a
                  href={`${REPO_BASE}/scripts/prompts/vibe-scorer.md`}
                  target="_blank"
                  rel="noopener"
                  class="judge-link"
                >
                  {lang === 'zh-tw' ? '風格評審' : 'Vibe Judge'}
                </a>
              </div>
            </div>
            <div class={`card-score ${scoreClass(vibeComposite)}`}>
              {vibeComposite}
              <span class="score-denom">/10</span>
            </div>
            <div class="vibe-sub">
              <span class="vibe-dim">
                {lang === 'zh-tw' ? '人物感' : 'Persona'}
                <strong class={scoreClass(vibeScores.persona)}>{vibeScores.persona}</strong>
              </span>
              <span class="vibe-sep">·</span>
              <span class="vibe-dim">
                ClawdNote
                <strong class={scoreClass(vibeScores.clawdNote)}>{vibeScores.clawdNote}</strong>
              </span>
              <span class="vibe-sep">·</span>
              <span class="vibe-dim">
                Vibe
                <strong class={scoreClass(vibeScores.vibe)}>{vibeScores.vibe}</strong>
              </span>
            </div>
          </div>
        )}
      </div>
    </div>
  )
}

<style>
  .ai-judge-panel {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background-color: var(--color-bg-secondary, rgba(0, 0, 0, 0.03));
    border-radius: 8px;
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
  }

  .judge-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .judge-title {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .judge-link {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .judge-link:hover {
    color: var(--color-accent);
  }

  .judge-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 639px) {
    .judge-cards {
      grid-template-columns: 1fr;
    }
  }

  .judge-card {
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .judge-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .judge-name {
    font-weight: 600;
    font-size: 0.85rem;
    line-height: 1.2;
  }

  .card-score {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }

  .score-denom {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Theme-aware judge brand colors — WCAG AA 4.5:1 contrast on card surface */
  /* Dark surface: #44475a → need bright variants */
  /* Light surface: #eee8d5 → need darker variants */
  .judge-color-curator {
    color: #78b4ff; /* bright blue — 4.26:1 on dark */
  }
  .judge-color-checker {
    color: #34d399; /* bright emerald — 4.76:1 on dark */
  }
  .judge-color-vibe {
    color: #fbbf24; /* bright amber — 5.48:1 on dark */
  }

  :global([data-theme='light']) .judge-color-curator {
    color: #1d4ed8; /* tailwind blue-700 */
  }
  :global([data-theme='light']) .judge-color-checker {
    color: #047857; /* tailwind emerald-700 */
  }
  :global([data-theme='light']) .judge-color-vibe {
    color: #a16207; /* tailwind yellow-700 */
  }

  /* Score value colors — also theme-aware */
  .score-neutral {
    color: #93a1a1; /* Solarized base1 — light gray on dark */
  }

  :global([data-theme='light']) .score-neutral {
    color: #586e75; /* Solarized base01 — muted gray on light */
  }

  .vibe-sub {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin-top: 0.1rem;
  }

  .vibe-dim {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .vibe-dim strong {
    font-weight: 600;
  }

  .vibe-sep {
    color: var(--color-border);
  }
</style>
