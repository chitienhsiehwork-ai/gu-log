---
// CodexNote component — ツッコミ（tsukkomi）role in the manzai trio
// Cold, factual, calls out BS. The straight man who slaps the comedian.
// Fact-checks, finds logical holes, delivers dry corrections with deadpan wit.

interface Props {
  /** Optional custom prefix */
  prefix?: string;
}

const { prefix } = Astro.props;

const prefixes = [
  'Codex 冷靜吐槽：',
  'Codex 打臉時間：',
  'Codex 等一下：',
  'Codex 事實查核：',
  'Codex 理性分析：',
  'Codex 潑冷水：',
  'Codex 不同意：',
  'Codex 翻白眼：',
  'Codex 嚴肅地說：',
  'Codex 挑個毛病：',
];

const slotContent = await Astro.slots.render('default');

function hashString(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = (hash << 5) - hash + char;
    hash = hash & hash;
  }
  return Math.abs(hash);
}

const contentHash = hashString(slotContent);
const selectedPrefix = prefix || prefixes[contentHash % prefixes.length];
---

<blockquote class="codex-note">
  <strong class="codex-prefix">
    <span class="codex-prefix-icon">▸</span>
    {selectedPrefix}
  </strong>
  <br />
  <Fragment set:html={slotContent} />
</blockquote>

<style>
  .codex-note {
    border-left: 4px solid #10a37f !important;
    background: rgba(16, 163, 127, 0.06) !important;
    font-style: normal;
    border-radius: 0 12px 12px 0 !important;
    padding: 1rem 1.25rem !important;
    margin: 1.5rem 0 !important;
  }

  .codex-prefix {
    color: var(--color-codex-green, #10a37f);
    font-size: 0.95em;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.3rem;
  }

  .codex-prefix-icon {
    display: inline-block;
    font-family: monospace;
    font-size: 1.1em;
    color: var(--color-codex-green, #10a37f);
  }

  /* Light theme */
  [data-theme='light'] .codex-note {
    border-left-color: #0d8c6d !important;
    background: rgba(13, 140, 109, 0.06) !important;
  }

  [data-theme='light'] .codex-prefix {
    color: #0d8c6d;
  }
</style>
