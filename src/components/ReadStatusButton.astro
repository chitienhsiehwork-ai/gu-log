---
interface Props {
  slug: string;
  lang?: 'zh-tw' | 'en';
  postId: string;
  ticketId?: string;
  postVersion: number;
  readerRevision?: string | null;
  pathname: string;
}

const {
  slug,
  lang = 'zh-tw',
  postId,
  ticketId,
  postVersion,
  readerRevision,
  pathname,
} = Astro.props;

const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.shroomdog.dev';
---

<div
  class="read-status-wrap"
  data-read-button
  data-slug={slug}
  data-lang={lang}
  data-post-id={postId}
  data-ticket-id={ticketId}
  data-post-version={postVersion}
  data-reader-revision={readerRevision}
  data-pathname={pathname}
  data-api-url={apiUrl}
  style="display:none"
>
  <button class="read-status-btn" type="button">
    <span class="rs-icon rs-icon-unread" aria-hidden="true">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="3" width="18" height="18" rx="3"></rect>
      </svg>
    </span>
    <span class="rs-icon rs-icon-read" aria-hidden="true">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="3" width="18" height="18" rx="3"></rect>
        <path d="m7 12 3 3 7-7"></path>
      </svg>
    </span>
    <span class="rs-label rs-label-unread">{lang === 'en' ? 'Mark as read' : '標記已讀'}</span>
    <span class="rs-label rs-label-read">{lang === 'en' ? 'Read' : '已讀'}</span>
  </button>
</div>

<script>
  import { isRead, toggleRead, markAsRead, exportJson, importJson } from '../lib/reading-tracker';
  import {
    getGitHubToken,
    getGuLogSessionToken,
    pushToGist,
    pushToReaderSyncApi,
    pullFromGist,
    pullFromReaderSyncApi,
    mergeSync,
  } from '../lib/gist-sync';
  import {
    recordManualMarkRead,
    recordReadAbandonCandidate,
    recordReadFinish,
  } from '../lib/human-signals';
  import type { ArticleVersionSnapshot, GuLogLang } from '../lib/human-signals';

  const LAST_SYNC_KEY = 'gu-log-last-sync';
  const SYNC_DIRTY_KEY = 'gu-log-sync-dirty';

  let syncDebounceTimer: ReturnType<typeof setTimeout> | null = null;

  function getSnapshot(el: HTMLElement): ArticleVersionSnapshot {
    return {
      postId: el.dataset.postId || el.dataset.slug || '',
      ticketId: el.dataset.ticketId || undefined,
      lang: (el.dataset.lang || 'zh-tw') as GuLogLang,
      pathname: el.dataset.pathname || window.location.pathname,
      postVersion: el.dataset.postVersion || '1',
    };
  }

  function scheduleDebouncedSync() {
    if (syncDebounceTimer !== null) clearTimeout(syncDebounceTimer);
    syncDebounceTimer = setTimeout(async () => {
      syncDebounceTimer = null;
      const jwt = getGuLogSessionToken();
      const legacyToken = getGitHubToken();
      if (!jwt && !legacyToken) return;
      try {
        const apiUrl =
          document.querySelector<HTMLElement>('[data-read-button]')?.dataset.apiUrl ||
          'https://api.shroomdog.dev';
        const remote = jwt ? await pullFromReaderSyncApi(apiUrl) : await pullFromGist(legacyToken!);
        const merged = mergeSync(JSON.parse(exportJson()), remote ?? []);
        importJson(JSON.stringify(merged));
        if (jwt) {
          await pushToReaderSyncApi(apiUrl, merged);
        } else {
          await pushToGist(legacyToken!, merged);
        }
        localStorage.setItem(LAST_SYNC_KEY, new Date().toISOString());
        localStorage.removeItem(SYNC_DIRTY_KEY);
      } catch {
        // Silent background failure — user will see status on tracker page
      }
    }, 5000);
  }

  function initReadButtons() {
    // Only show when logged in
    const jwt = localStorage.getItem('gu-log-jwt');
    if (!jwt) return;

    document.querySelectorAll<HTMLElement>('[data-read-button]').forEach((el) => {
      el.style.display = '';

      const slug = el.dataset.slug || '';
      const btn = el.querySelector<HTMLButtonElement>('.read-status-btn');
      const readerRevision = el.dataset.readerRevision || null;
      if (!btn) return;

      function updateUI(read: boolean) {
        const iconUnread = el.querySelector<HTMLElement>('.rs-icon-unread')!;
        const iconRead = el.querySelector<HTMLElement>('.rs-icon-read')!;
        const labelUnread = el.querySelector<HTMLElement>('.rs-label-unread')!;
        const labelRead = el.querySelector<HTMLElement>('.rs-label-read')!;

        if (read) {
          iconUnread.style.display = 'none';
          iconRead.style.display = '';
          labelUnread.style.display = 'none';
          labelRead.style.display = '';
          btn!.classList.add('is-read');
        } else {
          iconUnread.style.display = '';
          iconRead.style.display = 'none';
          labelUnread.style.display = '';
          labelRead.style.display = 'none';
          btn!.classList.remove('is-read');
        }
      }

      // Hide "read" variants initially via CSS, update here
      el.querySelector<HTMLElement>('.rs-icon-read')!.style.display = 'none';
      el.querySelector<HTMLElement>('.rs-label-read')!.style.display = 'none';

      updateUI(isRead(slug));

      btn.addEventListener('click', () => {
        const nowRead = toggleRead(slug, readerRevision);
        if (nowRead) {
          recordManualMarkRead(getSnapshot(el));
        }
        updateUI(nowRead);
        // Dispatch event for any dashboard that might be listening
        window.dispatchEvent(
          new CustomEvent('read-status-changed', { detail: { slug, read: nowRead } })
        );
        // Mark dirty and schedule a debounced background sync
        if (localStorage.getItem(LAST_SYNC_KEY)) {
          localStorage.setItem(SYNC_DIRTY_KEY, 'true');
        }
        scheduleDebouncedSync();
      });
    });
  }

  // Auto-mark as read when scrolled to near bottom
  function initScrollRead() {
    const jwt = localStorage.getItem('gu-log-jwt');
    if (!jwt) return;

    const el = document.querySelector<HTMLElement>('[data-read-button]');
    if (!el) return;
    const slug = el.dataset.slug || '';
    const readerRevision = el.dataset.readerRevision || null;
    if (!slug || isRead(slug)) return;

    const postContent = document.querySelector('.post-content');
    if (!postContent) return;
    const postContentEl = postContent as HTMLElement;

    const ACTIVE_WINDOW_MS = 5_000;
    const FINISH_SCROLL_GUARD_PERCENT = 95;
    let maxScrollPercent = 0;
    let activeReadMs = 0;
    let lastTickAt = Date.now();
    let lastActivityAt = Date.now();
    let finished = false;

    function checkpointActiveRead() {
      const now = Date.now();
      const elapsedMs = Math.max(0, now - lastTickAt);
      if (document.visibilityState === 'visible' && now - lastActivityAt <= ACTIVE_WINDOW_MS) {
        activeReadMs += elapsedMs;
      }
      lastTickAt = now;
      return activeReadMs;
    }

    function updateMaxScroll() {
      const rect = postContentEl.getBoundingClientRect();
      const visibleBottom = window.innerHeight - rect.top;
      const percent = Math.max(0, Math.min(100, Math.round((visibleBottom / rect.height) * 100)));
      if (percent > maxScrollPercent) maxScrollPercent = percent;
    }

    function noteReaderActivity() {
      checkpointActiveRead();
      lastActivityAt = Date.now();
      updateMaxScroll();
    }

    function markDirtyForSync() {
      if (localStorage.getItem(LAST_SYNC_KEY)) {
        localStorage.setItem(SYNC_DIRTY_KEY, 'true');
      }
    }

    function cleanupTracking() {
      window.removeEventListener('scroll', noteReaderActivity);
      window.removeEventListener('pointerdown', noteReaderActivity);
      window.removeEventListener('keydown', noteReaderActivity);
      window.removeEventListener('touchstart', noteReaderActivity);
      document.removeEventListener('visibilitychange', checkpointActiveRead);
      window.removeEventListener('pagehide', recordAbandonIfNeeded);
      observer.disconnect();
    }

    function recordAbandonIfNeeded() {
      const measuredActiveReadMs = checkpointActiveRead();
      updateMaxScroll();
      if (
        finished ||
        isRead(slug) ||
        maxScrollPercent <= 0 ||
        maxScrollPercent >= FINISH_SCROLL_GUARD_PERCENT
      ) {
        return;
      }
      recordReadAbandonCandidate(getSnapshot(el!), {
        activeReadMs: measuredActiveReadMs,
        maxScrollPercent,
        finishability:
          measuredActiveReadMs >= 30_000 && maxScrollPercent < 80
            ? 'abandoned_suspected_boring'
            : 'abandoned_unknown',
      });
      markDirtyForSync();
    }

    window.addEventListener('scroll', noteReaderActivity, { passive: true });
    window.addEventListener('pointerdown', noteReaderActivity, { passive: true });
    window.addEventListener('keydown', noteReaderActivity);
    window.addEventListener('touchstart', noteReaderActivity, { passive: true });
    document.addEventListener('visibilitychange', checkpointActiveRead);
    window.addEventListener('pagehide', recordAbandonIfNeeded);
    updateMaxScroll();

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          // Bottom of content visible — mark as read synchronously enough to avoid pagehide races.
          finished = true;
          markAsRead(slug, 'active_scroll_end', readerRevision);
          recordReadFinish(getSnapshot(el!), {
            method: 'active_scroll_end',
            activeReadMs: checkpointActiveRead(),
            maxScrollPercent: Math.max(maxScrollPercent, 100),
          });
          markDirtyForSync();
          scheduleDebouncedSync();
          // Update button UI
          document.querySelectorAll<HTMLElement>('[data-read-button]').forEach((btn) => {
            if (btn.dataset.slug === slug) {
              btn.querySelector<HTMLElement>('.rs-icon-unread')!.style.display = 'none';
              btn.querySelector<HTMLElement>('.rs-icon-read')!.style.display = '';
              btn.querySelector<HTMLElement>('.rs-label-unread')!.style.display = 'none';
              btn.querySelector<HTMLElement>('.rs-label-read')!.style.display = '';
              btn.querySelector<HTMLButtonElement>('.read-status-btn')!.classList.add('is-read');
            }
          });
          cleanupTracking();
        }
      },
      { threshold: 1.0, rootMargin: '0px 0px -50px 0px' }
    );

    // Observe the last paragraph/element in post-content
    const children = postContent.children;
    if (children.length > 0) {
      observer.observe(children[children.length - 1]);
    }
  }

  initReadButtons();
  initScrollRead();
</script>

<style>
  .read-status-wrap {
    margin: 1.5rem 0 0.5rem;
    display: flex;
    justify-content: flex-end;
  }

  .read-status-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.875rem;
    padding: 0.35rem 0.75rem;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background-color 0.2s ease;
    font-family: var(--font-sans);
    line-height: 1.4;
  }

  .read-status-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .read-status-btn.is-read {
    border-color: var(--color-status-success);
    color: var(--color-status-success);
    background-color: var(--color-status-success-soft-bg);
  }
</style>
