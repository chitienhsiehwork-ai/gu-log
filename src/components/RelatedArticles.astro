---
/**
 * RelatedArticles — Tag-based recommendations for posts WITHOUT a series (Issue #83)
 *
 * Shown above PrevNextNav when the current post has no `series` field.
 * Finds posts with the most tag overlap, sorts unread-first client-side.
 */

interface Post {
  id: string;
  data: {
    title: string;
    ticketId?: string;
    tags?: string[];
    originalDate: string;
    lang: string;
    series?: { name: string; order: number };
  };
}

interface Props {
  currentSlug: string;
  currentTags: string[];
  allPosts: Post[];
  lang?: 'zh-tw' | 'en';
}

const { currentSlug, currentTags, allPosts, lang = 'zh-tw' } = Astro.props;

const labels = {
  'zh-tw': { heading: '相關文章', unread: '未讀', read: '已讀' },
  en: { heading: 'Related Articles', unread: 'Unread', read: 'Read' },
};
const t = labels[lang];
const baseUrl = lang === 'en' ? '/en/posts/' : '/posts/';

// Compute tag-overlap score for all other posts in same lang
const scored = allPosts
  .filter((p) => p.id !== currentSlug && !p.data.series)
  .map((p) => {
    const overlap = (p.data.tags ?? []).filter((tag) => currentTags.includes(tag)).length;
    return { post: p, overlap };
  })
  .filter((s) => s.overlap > 0)
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap;
    // Tiebreak: newest first
    return (
      new Date(b.post.data.originalDate).getTime() - new Date(a.post.data.originalDate).getTime()
    );
  })
  .slice(0, 3);

// If no tag overlap, fallback to 3 most recent posts
const related =
  scored.length > 0
    ? scored.map((s) => s.post)
    : allPosts
        .filter((p) => p.id !== currentSlug && !p.data.series)
        .sort(
          (a, b) =>
            new Date(b.data.originalDate).getTime() - new Date(a.data.originalDate).getTime()
        )
        .slice(0, 3);
---

{
  related.length > 0 && (
    <section class="related-articles" data-related-articles aria-label={t.heading}>
      <div class="related-header">
        <span class="related-heading-icon" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            width="17"
            height="17"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z" />
          </svg>
        </span>
        <h3 class="related-heading">{t.heading}</h3>
      </div>
      <ul class="related-list" id="related-list">
        {related.map((post) => (
          <li class="related-card" data-related-item data-slug={post.id}>
            <span class="read-dot" data-read-indicator data-slug={post.id} />
            <a href={`${baseUrl}${post.id}`} class="related-link">
              {post.data.ticketId && <span class="ticket-id">{post.data.ticketId}</span>}
              <span class="related-title">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<script>
  import { isRead } from '../lib/reading-tracker';

  function initRelatedArticles() {
    const section = document.querySelector<HTMLElement>('[data-related-articles]');
    if (!section) return;

    const list = section.querySelector<HTMLElement>('#related-list');
    if (!list) return;

    const items = Array.from(list.querySelectorAll<HTMLElement>('li.related-card'));

    // Update read indicators
    items.forEach((li) => {
      const indicator = li.querySelector<HTMLElement>('[data-read-indicator]');
      const slug = li.dataset.slug ?? '';
      const read = isRead(slug);
      if (indicator) {
        indicator.classList.toggle('is-read', read);
        indicator.title = read ? 'Read' : 'Unread';
      }
      li.dataset.isRead = read ? '1' : '0';
    });

    // Reorder: unread first, then read (stable sort preserving original rank within groups)
    const unread = items.filter((li) => li.dataset.isRead === '0');
    const read = items.filter((li) => li.dataset.isRead === '1');
    const reordered = [...unread, ...read];
    reordered.forEach((li) => list.appendChild(li));

    // Listen for external read-status changes (from ReadStatusButton)
    window.addEventListener('read-status-changed', (e: Event) => {
      const detail = (e as CustomEvent<{ slug: string; read: boolean }>).detail;
      const indicator = section.querySelector<HTMLElement>(
        `[data-read-indicator][data-slug="${detail.slug}"]`
      );
      if (indicator) {
        indicator.classList.toggle('is-read', detail.read);
        indicator.title = detail.read ? 'Read' : 'Unread';
      }
    });
  }

  initRelatedArticles();
</script>

<style>
  .related-articles {
    margin: 2rem 0 1rem;
    box-sizing: border-box;
  }

  /* Header row */
  .related-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .related-heading-icon {
    display: inline-flex;
    color: var(--color-text-muted);
  }
  .related-heading {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }

  /* Card list */
  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-divider);
  }

  /* Editorial list row */
  .related-card {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-divider);
  }
  .related-card:hover .ticket-id,
  .related-card:hover .related-title {
    color: var(--color-source-link);
  }

  /* Read dot */
  .read-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.4rem;
    background: var(--color-text-muted);
    opacity: 0.65;
    transition: all 0.2s ease;
  }
  .read-dot.is-read {
    background: var(--color-status-success);
    opacity: 0.35;
  }

  /* Link */
  .related-link {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    min-height: 44px;
    text-decoration: none;
    color: var(--color-text);
    flex: 1;
    min-width: 0;
  }
  .related-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Ticket ID label */
  .ticket-id {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Title */
  .related-title {
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-surface-meta);
    word-break: break-word;
    overflow-wrap: anywhere;
    transition: color 0.15s ease;
  }

  @media (max-width: 640px) {
    .related-card {
      padding: 0.8rem 0;
    }
  }

  @media (pointer: coarse) {
    .related-card {
      min-height: 52px;
    }
  }
</style>
