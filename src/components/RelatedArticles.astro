---
/**
 * RelatedArticles — Tag-based recommendations for posts WITHOUT a series (Issue #83)
 *
 * Shown above PrevNextNav when the current post has no `series` field.
 * Finds posts with the most tag overlap, sorts unread-first client-side.
 */

interface Post {
  slug: string;
  data: {
    title: string;
    ticketId?: string;
    tags?: string[];
    originalDate: string;
    lang: string;
    series?: { name: string; order: number };
  };
}

interface Props {
  currentSlug: string;
  currentTags: string[];
  allPosts: Post[];
  lang?: 'zh-tw' | 'en';
}

const { currentSlug, currentTags, allPosts, lang = 'zh-tw' } = Astro.props;

const labels = {
  'zh-tw': { heading: '相關文章', unread: '未讀', read: '已讀' },
  en: { heading: 'Related Articles', unread: 'Unread', read: 'Read' },
};
const t = labels[lang];
const baseUrl = lang === 'en' ? '/en/posts/' : '/posts/';

// Compute tag-overlap score for all other posts in same lang
const scored = allPosts
  .filter((p) => p.slug !== currentSlug && !p.data.series)
  .map((p) => {
    const overlap = (p.data.tags ?? []).filter((tag) => currentTags.includes(tag)).length;
    return { post: p, overlap };
  })
  .filter((s) => s.overlap > 0)
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap;
    // Tiebreak: newest first
    return (
      new Date(b.post.data.originalDate).getTime() - new Date(a.post.data.originalDate).getTime()
    );
  })
  .slice(0, 3);

// If no tag overlap, fallback to 3 most recent posts
const related =
  scored.length > 0
    ? scored.map((s) => s.post)
    : allPosts
        .filter((p) => p.slug !== currentSlug && !p.data.series)
        .sort(
          (a, b) =>
            new Date(b.data.originalDate).getTime() - new Date(a.data.originalDate).getTime()
        )
        .slice(0, 3);
---

{
  related.length > 0 && (
    <section class="related-articles" data-related-articles aria-label={t.heading}>
      <h3 class="related-heading">{t.heading}</h3>
      <ul class="related-list" id="related-list">
        {related.map((post) => (
          <li class="related-item">
            <span class="read-indicator" data-read-indicator data-slug={post.slug} />
            <a
              href={`${baseUrl}${post.slug}`}
              class="related-link"
              data-related-item
              data-slug={post.slug}
            >
              {post.data.ticketId && (
                <span
                  class={`ticket-badge ticket-${post.data.ticketId.split('-')[0].toLowerCase()}`}
                >
                  {post.data.ticketId}
                </span>
              )}
              <span class="related-title">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<script>
  import { isRead } from '../lib/reading-tracker';

  function initRelatedArticles() {
    const section = document.querySelector<HTMLElement>('[data-related-articles]');
    if (!section) return;

    const list = section.querySelector<HTMLElement>('#related-list');
    if (!list) return;

    const items = Array.from(list.querySelectorAll<HTMLElement>('li.related-item'));

    // Update read indicators
    items.forEach((li) => {
      const indicator = li.querySelector<HTMLElement>('[data-read-indicator]');
      const link = li.querySelector<HTMLElement>('[data-related-item]');
      const slug = link?.dataset.slug ?? '';
      const read = isRead(slug);
      if (indicator) {
        indicator.classList.toggle('is-read', read);
        indicator.title = read ? 'Read' : 'Unread';
      }
      li.dataset.isRead = read ? '1' : '0';
    });

    // Reorder: unread first, then read (stable sort preserving original rank within groups)
    const unread = items.filter((li) => li.dataset.isRead === '0');
    const read = items.filter((li) => li.dataset.isRead === '1');
    const reordered = [...unread, ...read];
    reordered.forEach((li) => list.appendChild(li));

    // Listen for external read-status changes (from ReadStatusButton)
    window.addEventListener('read-status-changed', (e: Event) => {
      const detail = (e as CustomEvent<{ slug: string; read: boolean }>).detail;
      const indicator = section.querySelector<HTMLElement>(
        `[data-read-indicator][data-slug="${detail.slug}"]`
      );
      if (indicator) {
        indicator.classList.toggle('is-read', detail.read);
        indicator.title = detail.read ? 'Read' : 'Unread';
      }
    });
  }

  initRelatedArticles();
</script>

<style>
  .related-articles {
    margin: 2rem 0 1rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-surface);
    box-sizing: border-box;
  }
  .related-heading {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }
  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .related-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .related-item:last-child {
    border-bottom: none;
  }
  .read-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: 1.5px solid var(--color-text-muted);
    flex-shrink: 0;
    margin-top: 0.35rem;
    transition: background 0.2s ease;
  }
  .read-indicator.is-read {
    background: var(--color-badge-sd, #50fa7b);
    border-color: var(--color-badge-sd, #50fa7b);
  }
  .related-link {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.875rem;
    line-height: 1.4;
    flex: 1;
    min-width: 0;
  }
  .related-link:hover {
    color: var(--color-accent);
  }
  .related-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .ticket-badge {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .ticket-sp {
    background: var(--color-badge-sp, rgba(255, 184, 108, 0.2));
    color: var(--color-badge-sp-text, #ffb86c);
    border: 1px solid var(--color-badge-sp, #ffb86c);
  }
  .ticket-cp {
    background: var(--color-badge-cp, rgba(189, 147, 249, 0.2));
    color: var(--color-badge-cp-text, #bd93f9);
    border: 1px solid var(--color-badge-cp, #bd93f9);
  }
  .ticket-sd {
    background: var(--color-badge-sd, rgba(80, 250, 123, 0.2));
    color: var(--color-badge-sd-text, #50fa7b);
    border: 1px solid var(--color-badge-sd, #50fa7b);
  }
  .ticket-lv {
    background: var(--color-badge-lv, rgba(255, 121, 198, 0.2));
    color: var(--color-badge-lv-text, #ff79c6);
    border: 1px solid var(--color-badge-lv, #ff79c6);
  }
  .related-title {
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  @media (max-width: 640px) {
    .related-articles {
      padding: 1rem;
    }
  }
</style>
