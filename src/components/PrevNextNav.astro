---
/**
 * Previous/Next Post Navigation Component
 *
 * Shows links to the previous and next posts (by date) at the bottom of each post.
 * Displays post title and date for each link.
 */

interface Props {
  currentSlug: string;
  allPosts: Array<{
    id: string;
    data: {
      title: string;
      originalDate: string;
      ticketId?: string;
      lang: string;
    };
  }>;
  lang?: 'zh-tw' | 'en';
}

const { currentSlug, allPosts, lang = 'zh-tw' } = Astro.props;

const labels = {
  'zh-tw': {
    previous: '← 上一篇',
    next: '下一篇 →',
    noPrevious: '這是第一篇文章',
    noNext: '這是最新文章',
  },
  en: {
    previous: '← Previous',
    next: 'Next →',
    noPrevious: 'This is the first post',
    noNext: 'This is the latest post',
  },
};

const t = labels[lang];

// Sort posts by originalDate (newest first)
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.originalDate).getTime() - new Date(a.data.originalDate).getTime();
});

// Find current post index
const currentIndex = sortedPosts.findIndex((post) => post.id === currentSlug);

// Previous post is newer (earlier in array)
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// Next post is older (later in array)
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

// Format date for display
function formatDate(dateStr: string, lang: string): string {
  const date = new Date(dateStr);
  if (lang === 'zh-tw') {
    return dateStr; // Keep YYYY-MM-DD format for zh-tw
  } else {
    // Format as "Mon DD, YYYY" for English
    return date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }
}

// Build post URLs
const baseUrl = lang === 'en' ? '/en/posts/' : '/posts/';
---

<nav class="prev-next-nav" aria-label={lang === 'zh-tw' ? '文章導航' : 'Post navigation'}>
  <div class="prev-next-header">
    <span class="prev-next-heading-icon" aria-hidden="true">
      <svg
        viewBox="0 0 24 24"
        width="17"
        height="17"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path d="m16 8-2.6 5.4L8 16l2.6-5.4L16 8Z"></path>
      </svg>
    </span>
    <span class="prev-next-heading">{lang === 'zh-tw' ? '依時間瀏覽' : 'Browse by Date'}</span>
  </div>
  <div class="prev-next-container">
    <div class="prev-link-wrapper">
      {
        prevPost ? (
          <a href={`${baseUrl}${prevPost.id}`} class="nav-card">
            <span class="nav-direction">{t.previous}</span>
            <span class="nav-post-title">{prevPost.data.title}</span>
            <span class="nav-post-meta">
              {prevPost.data.ticketId && <span class="nav-ticket">{prevPost.data.ticketId}</span>}
              <span class="nav-post-date">{formatDate(prevPost.data.originalDate, lang)}</span>
            </span>
          </a>
        ) : (
          <span class="nav-card nav-card--disabled">
            <span class="nav-direction">{t.previous}</span>
            <span class="nav-post-title nav-placeholder">{t.noPrevious}</span>
          </span>
        )
      }
    </div>

    <div class="next-link-wrapper">
      {
        nextPost ? (
          <a href={`${baseUrl}${nextPost.id}`} class="nav-card">
            <span class="nav-direction">{t.next}</span>
            <span class="nav-post-title">{nextPost.data.title}</span>
            <span class="nav-post-meta">
              {nextPost.data.ticketId && <span class="nav-ticket">{nextPost.data.ticketId}</span>}
              <span class="nav-post-date">{formatDate(nextPost.data.originalDate, lang)}</span>
            </span>
          </a>
        ) : (
          <span class="nav-card nav-card--disabled">
            <span class="nav-direction">{t.next}</span>
            <span class="nav-post-title nav-placeholder">{t.noNext}</span>
          </span>
        )
      }
    </div>
  </div>
</nav>

<style>
  .prev-next-nav {
    margin: 2rem 0 1rem;
  }

  /* Section header — matches RelatedArticles */
  .prev-next-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .prev-next-heading-icon {
    display: inline-flex;
    color: var(--color-text-muted);
  }
  .prev-next-heading {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .prev-next-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    border-top: 1px solid var(--color-divider);
  }

  /* Editorial navigation rows */
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.9rem 0;
    text-decoration: none;
    cursor: pointer;
  }

  a.nav-card:hover .nav-post-title,
  a.nav-card:hover .nav-ticket {
    color: var(--color-source-link);
  }

  .nav-card--disabled {
    opacity: 0.4;
    cursor: default;
  }

  .nav-direction {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-source-link);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .nav-post-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-surface-meta);
    line-height: 1.45;
    transition: color 0.15s ease;
  }
  .nav-placeholder {
    font-style: italic;
    opacity: 0.7;
  }

  .nav-post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.15rem;
  }

  /* Ticket ID as text label — matches RelatedArticles */
  .nav-ticket {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .nav-post-date {
    font-size: 0.7rem;
    color: var(--color-surface-meta);
  }

  /* Mobile: Stack vertically */
  @media (max-width: 640px) {
    .prev-next-container {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .next-link-wrapper {
      border-top: 1px solid var(--color-divider);
    }
  }

  /* Touch-friendly sizing */
  @media (pointer: coarse) {
    .nav-card {
      padding: 0.9rem 0;
      min-height: 64px;
    }
  }

  /* Focus styles */
  a.nav-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
