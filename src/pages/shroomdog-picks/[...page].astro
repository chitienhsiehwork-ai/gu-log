---
import { getCollection } from 'astro:content';
import type { GetStaticPathsOptions } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TicketBadge from '../../components/TicketBadge.astro';
import Toggle from '../../components/Toggle.astro';
import PostStatusLabel from '../../components/PostStatusLabel.astro';
import Pagination from '../../components/Pagination.astro';
import { getListablePosts, getPostStatus, type PostStatus } from '../../utils/post-status';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const getTicketNumber = (ticketId: string | undefined) => {
    if (!ticketId) return 0;
    const match = ticketId.match(/\d+$/);
    return match ? parseInt(match[0]) : 0;
  };
  const allPostsFull = await getCollection('posts');
  const spPosts = getListablePosts(allPostsFull, 'zh-tw')
    .filter((post) => post.data.ticketId?.startsWith('SP-'))
    .sort((a, b) => getTicketNumber(b.data.ticketId) - getTicketNumber(a.data.ticketId));
  return paginate(spPosts, { pageSize: 20 });
}

const { page } = Astro.props;
const allPostsFull = await getCollection('posts');
const getTimelineStyle = (status: PostStatus) =>
  status === 'published' ? undefined : 'opacity: 0.6; filter: grayscale(0.22);';
---

<BaseLayout title="ShroomDog Picks 全部文章">
  <h1>📚 ShroomDog Picks</h1>
  <p class="page-subtitle">ShroomDog 精選長文翻譯</p>
  <p class="post-count">共 {page.total} 篇</p>

  <a href="/" class="back-link">← 返回首頁</a>

  <section class="archive-list">
    {
      page.data.map((post) => {
        const status = getPostStatus(post, allPostsFull);
        return (
          <article class="post-preview" style={getTimelineStyle(status)}>
            <h3>
              <a href={`/posts/${post.slug}`}>
                {post.data.title}
                {status !== 'published' && <PostStatusLabel status={status} />}
              </a>
            </h3>
            <p class="post-meta">
              {post.data.ticketId && <TicketBadge ticketId={post.data.ticketId} />}
              {post.data.translatedDate || post.data.originalDate} · 翻譯自 {post.data.source}
            </p>
            <Toggle title="摘要預覽">
              <p>{post.data.summary}</p>
            </Toggle>
          </article>
        );
      })
    }
  </section>

  <Pagination page={page} lang="zh-tw" />
</BaseLayout>

<style>
  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .archive-list {
    margin-bottom: 2rem;
  }

  .post-preview {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-divider);
  }

  .post-preview h3 {
    line-height: 1.35;
    margin-bottom: 0.15rem;
  }

  .post-preview h3 a {
    color: var(--color-text);
  }

  .post-preview h3 a:hover {
    color: var(--color-accent);
  }
</style>
