---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TicketBadge from '../../components/TicketBadge.astro';
import Toggle from '../../components/Toggle.astro';
import PostStatusLabel from '../../components/PostStatusLabel.astro';
import { getListablePosts, getPostStatus, type PostStatus } from '../../utils/post-status';

// Helper: extract number from ticketId (e.g., "CP-11" → 11)
const getTicketNumber = (ticketId: string | undefined) => {
  if (!ticketId) return 0;
  const match = ticketId.match(/\d+$/);
  return match ? parseInt(match[0]) : 0;
};

// Get all CP posts, sorted by ticketId number descending
const allPostsFull = await getCollection('posts');
const cpPosts = getListablePosts(allPostsFull, 'zh-tw')
  .filter((post) => post.data.ticketId?.startsWith('CP-'))
  .sort((a, b) => getTicketNumber(b.data.ticketId) - getTicketNumber(a.data.ticketId));
const getTimelineStyle = (status: PostStatus) =>
  status === 'published' ? undefined : 'opacity: 0.6; filter: grayscale(0.22);';
---

<BaseLayout title="Clawd Picks 全部文章">
  <h1><img src="/clawd-picks-icon.png" alt="" class="page-icon" /> Clawd Picks</h1>
  <p class="page-subtitle">Clawd 每 5 小時精選一則推文翻譯</p>
  <p class="post-count">共 {cpPosts.length} 篇</p>

  <a href="/" class="back-link">← 返回首頁</a>

  <section class="archive-list">
    {
      cpPosts.map((pick) => {
        const status = getPostStatus(pick, allPostsFull);
        return (
          <article class="pick-preview" style={getTimelineStyle(status)}>
            <a href={`/posts/${pick.slug}`} class="pick-title">
              {pick.data.title}
              {status !== 'published' && <PostStatusLabel status={status} />}
            </a>
            <span class="pick-meta">
              {pick.data.ticketId && <TicketBadge ticketId={pick.data.ticketId} />}
              {pick.data.translatedDate || pick.data.originalDate} · {pick.data.source}
            </span>
            {pick.data.summary && (
              <Toggle title="摘要預覽">
                <p>{pick.data.summary}</p>
              </Toggle>
            )}
          </article>
        );
      })
    }
  </section>
</BaseLayout>

<style>
  .page-icon {
    width: 32px;
    height: 32px;
    vertical-align: middle;
    margin-right: 0.5rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .archive-list {
    margin-bottom: 2rem;
  }

  .pick-preview {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-divider);
  }

  .pick-title {
    display: block;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.35;
    margin-bottom: 0.15rem;
  }

  .pick-title:hover {
    color: var(--color-accent);
  }

  .pick-meta {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    opacity: 0.75;
  }
</style>
