---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClawdNote from '../../components/ClawdNote.astro';
import '../../styles/glossary.css';
import glossaryData from '../../data/glossary.json';

const glossary = [...glossaryData].sort((a, b) => a.term.localeCompare(b.term));

const categories: { id: string; label: string }[] = [
  { id: 'all', label: 'All' },
  { id: 'tools', label: 'Tools' },
  { id: 'concepts', label: 'Concepts' },
  { id: 'methods', label: 'Methods' },
  { id: 'platforms', label: 'Platforms' },
  { id: 'people', label: 'People' },
];

const categoryLabel: Record<string, string> = {
  tools: 'Tools',
  concepts: 'Concepts',
  methods: 'Methods',
  platforms: 'Platforms',
  people: 'People',
};

function isExternalUrl(url: string) {
  return /^https?:\/\//.test(url);
}

function urlLabel(url: string) {
  if (!isExternalUrl(url)) return `gu-log${url}`;

  const u = new URL(url);
  const host = u.hostname.replace('www.', '');
  const parts = u.pathname.split('/').filter(Boolean);
  const skip = /^(en|zh|ja|ko|de|fr|es|pt|ru)$/i;
  const first = parts.find((p) => !skip.test(p));
  return first ? `${host}/${first}` : host;
}

function termAnchor(item: (typeof glossary)[number]) {
  return item.linking?.anchor ?? item.term.toLowerCase().replace(/\s+/g, '-');
}

// Group by first letter
const grouped: { letter: string; items: typeof glossary }[] = [];
let currentLetter = '';
for (const item of glossary) {
  const letter = item.term[0].toUpperCase();
  if (letter !== currentLetter) {
    currentLetter = letter;
    grouped.push({ letter, items: [item] });
  } else {
    grouped[grouped.length - 1].items.push(item);
  }
}

const allLetters = grouped.map((g) => g.letter);
---

<BaseLayout title="Glossary - gu-log" lang="en">
  <article class="glossary-page">
    <header>
      <h1>📖 Glossary</h1>
      <p class="glossary-intro">
        AI terms that show up often on gu-log. Click a term name to copy its anchor link.
      </p>
    </header>

    <div class="glossary-controls">
      <input
        type="search"
        id="glossary-search"
        class="glossary-search"
        placeholder="Search terms..."
        aria-label="Search terms"
      />
      <div class="controls-row">
        <div class="category-pills" role="group" aria-label="Category filter">
          {
            categories.map((cat) => (
              <button
                class="category-pill"
                data-category={cat.id}
                aria-pressed={cat.id === 'all' ? 'true' : 'false'}
              >
                {cat.label}
              </button>
            ))
          }
        </div>
        <span class="glossary-count" id="glossary-count">{glossary.length} terms</span>
      </div>
    </div>

    {/* Alphabet jump bar */}
    <nav class="alpha-bar" aria-label="Alphabet index">
      {
        allLetters.map((l) => (
          <a href={`#letter-${l}`} class="alpha-link">
            {l}
          </a>
        ))
      }
    </nav>

    <div id="glossary-list">
      {
        grouped.map((group) => (
          <section class="letter-section" data-letter={group.letter} id={`letter-${group.letter}`}>
            <h2 class="letter-heading">{group.letter}</h2>
            <dl class="section-list">
              {group.items.map((item) => (
                <div
                  class="glossary-entry"
                  id={termAnchor(item)}
                  data-term={item.term.toLowerCase()}
                  data-en={item.en.toLowerCase()}
                  data-definition={(item.enDefinition ?? item.definition).toLowerCase()}
                  data-aliases={(item.aliases ?? []).join(' ').toLowerCase()}
                  data-category={item.category}
                >
                  <dt>
                    <a href={`#${termAnchor(item)}`} class="term-link">
                      {item.term}
                    </a>
                    {item.en !== item.term && <span class="term-en">{item.en}</span>}
                    <span class={`term-cat cat-${item.category}`}>
                      {categoryLabel[item.category] || item.category}
                    </span>
                  </dt>
                  <dd>
                    <p class="term-def">{item.enDefinition ?? item.definition}</p>
                    {item.enClawdNote && <ClawdNote>{item.enClawdNote}</ClawdNote>}
                    {item.url && (
                      <p class="term-meta">
                        <a
                          href={item.url}
                          target={isExternalUrl(item.url) ? '_blank' : undefined}
                          rel={isExternalUrl(item.url) ? 'noopener noreferrer' : undefined}
                        >
                          {urlLabel(item.url)}
                          {isExternalUrl(item.url) && ' ↗'}
                        </a>
                      </p>
                    )}
                    {item.thread && (
                      <p class="term-meta">
                        Thread:{' '}
                        <a href={item.thread.url} target="_blank" rel="noopener noreferrer">
                          {item.thread.enTitle ?? item.thread.title ?? urlLabel(item.thread.url)} ↗
                        </a>
                      </p>
                    )}
                    {(item.related?.length > 0 || item.definedIn?.length > 0) && (
                      <p class="term-meta">
                        {item.related?.length > 0 && (
                          <span class="meta-links">
                            →{' '}
                            {item.related.map((rel, i) => (
                              <span>
                                <a href={`#${rel.toLowerCase().replace(/\s+/g, '-')}`}>{rel}</a>
                                {i < item.related.length - 1 && ', '}
                              </span>
                            ))}
                          </span>
                        )}
                        {item.definedIn?.length > 0 && (
                          <span class="meta-posts">
                            {' '}
                            | Posts:{' '}
                            {item.definedIn.map(
                              (post: { slug: string; title: string }, i: number) => (
                                <span>
                                  <a href={`/en/posts/en-${post.slug}`}>{post.title}</a>
                                  {i < item.definedIn.length - 1 && ', '}
                                </span>
                              )
                            )}
                          </span>
                        )}
                      </p>
                    )}
                  </dd>
                </div>
              ))}
            </dl>
          </section>
        ))
      }
    </div>

    <p class="glossary-empty" id="glossary-empty" style="display:none">No matching terms.</p>

    <footer class="glossary-footer">
      <a href="/en">← Back home</a>
    </footer>
  </article>
</BaseLayout>

<script>
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
  const entries = document.querySelectorAll<HTMLElement>('.glossary-entry');
  const sections = document.querySelectorAll<HTMLElement>('.letter-section');
  const countEl = document.getElementById('glossary-count');
  const emptyEl = document.getElementById('glossary-empty');

  let activeCategory = 'all';

  function filterItems() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    entries.forEach((entry) => {
      const matchesCategory = activeCategory === 'all' || entry.dataset.category === activeCategory;
      const matchesSearch =
        !query ||
        entry.dataset.term?.includes(query) ||
        entry.dataset.en?.includes(query) ||
        entry.dataset.definition?.includes(query) ||
        entry.dataset.aliases?.includes(query);

      const show = matchesCategory && matchesSearch;
      entry.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    sections.forEach((section) => {
      const hasVisible = Array.from(section.querySelectorAll('.glossary-entry')).some(
        (e) => (e as HTMLElement).style.display !== 'none'
      );
      section.style.display = hasVisible ? '' : 'none';
    });

    if (countEl) countEl.textContent = `${visible} terms`;
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
  }

  searchInput?.addEventListener('input', filterItems);

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      activeCategory = pill.dataset.category ?? 'all';
      pills.forEach((p) => p.setAttribute('aria-pressed', 'false'));
      pill.setAttribute('aria-pressed', 'true');
      filterItems();
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('.term-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const url = new URL(link.href);
      navigator.clipboard.writeText(url.toString());
      history.replaceState(null, '', url.hash);
      link.classList.add('copied');
      setTimeout(() => link.classList.remove('copied'), 1200);
    });
  });
</script>
