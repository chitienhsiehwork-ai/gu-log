---
import { getCollection, render } from 'astro:content';
import { getPostReaderRevision, getPostVersion } from '../../../utils/post-versions';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import PrevNextNav from '../../../components/PrevNextNav.astro';
import SeriesNav from '../../../components/SeriesNav.astro';
import RelatedArticles from '../../../components/RelatedArticles.astro';
import PostStatusBanner from '../../../components/PostStatusBanner.astro';
import Stage0WarnBanner from '../../../components/Stage0WarnBanner.astro';
import Stage4DegradedBanner from '../../../components/Stage4DegradedBanner.astro';
import Sub8RefiningBanner from '../../../components/Sub8RefiningBanner.astro';
import { computeOverallComposite, isBelowPublishBar } from '../../../utils/tribunal-scores';
import TicketBadge from '../../../components/TicketBadge.astro';
import Giscus from '../../../components/Giscus.astro';
import AiPopup from '../../../components/AiPopup.astro';
import ArticleActionArea from '../../../components/ArticleActionArea.astro';
import ArticleTechnicalDetails from '../../../components/ArticleTechnicalDetails.astro';
import { getPostAuthorshipNote } from '../../../utils/post-authorship-notes';
import { getNavigablePosts, resolvePostStatus } from '../../../utils/post-status';
import { getLocalizedPostUrl } from '../../../utils/post-urls';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const posts = allPosts.filter((post) => post.data.lang === 'en');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
      allPosts,
    },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const ticketId = post.data.ticketId;
const ticketPrefix = ticketId?.split('-')[0] || '';
const isMoguPicks = ticketId?.startsWith('MP-') ?? false;
const isLevelUp = ticketId?.startsWith('Lv-') ?? false;
const isShroomDogOriginal = ticketId?.startsWith('SD-') ?? false;
// SD/Lv are originals — the model signature is "written by", not "translated by".
const isOriginalPost = isLevelUp || isShroomDogOriginal;
const isChatGptShareSource = post.data.sourceUrl.startsWith('https://chatgpt.com/share/');
// Lv tutorials are originals, but when one is built on a real external source
// (not a self-referential gu-log link) the source should still be credited + linked.
const hasExternalSource =
  !!post.data.sourceUrl && !post.data.sourceUrl.includes('gu-log.vercel.app');
const showSourceCitation =
  (!isLevelUp && (!isShroomDogOriginal || isChatGptShareSource)) ||
  (isLevelUp && hasExternalSource);
const sourceCitationLabel = isLevelUp
  ? 'Reference source'
  : isShroomDogOriginal && isChatGptShareSource
    ? 'Inspiration source'
    : 'Original source';
// Legacy Lv posts encoded the gu-log series name into `source`.
// The Lv badge already carries that context, so credit only the real source.
const sourceCitationText = post.data.source.replace(/^Level-Up Series\s*[／/]\s*/, '');

// Reader-state records in the wild are keyed by the legacy entry id
// (filename incl. extension) — keep sending that exact value as postId.
const legacyPostId = post.filePath?.split('/').pop() ?? post.id;
const postVersion = getPostVersion(post.id);
const postReaderRevision = getPostReaderRevision(post.id);
const authorshipNote = getPostAuthorshipNote(post.id, 'en');
const postStatus = resolvePostStatus(post, allPosts);
const canonicalPostUrl = new URL(getLocalizedPostUrl(post), Astro.site).href;
const markdownUrl = `${canonicalPostUrl}.md`;
const replacementUrl = postStatus.replacementPost
  ? new URL(getLocalizedPostUrl(postStatus.replacementPost), Astro.site).href
  : null;
const navigablePosts = getNavigablePosts(allPosts, post);

const ticketLabels: Record<string, string> = {
  SD: 'ShroomDog Original',
  GP: 'Gu-log Picks',
  MP: 'Mogu Picks',
};
const ticketLabel = ticketLabels[ticketPrefix] || '';
---

<BaseLayout title={`${post.data.title} - gu-log`} lang="en" markdownUrl={markdownUrl}>
  <article
    class="post"
    data-post-representation
    data-post-slug={post.id}
    data-post-lang={post.data.lang}
    data-post-status={postStatus.status}
    data-replacement-ticket-id={postStatus.replacementTicketId ?? ''}
    data-replacement-url={replacementUrl ?? ''}
  >
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta-row">
        <span class="post-meta-left">
          {ticketId && <TicketBadge ticketId={ticketId} />}
          <span class="meta-date">{post.data.translatedDate || post.data.originalDate}</span>
          {
            isMoguPicks && (
              <span class="mogu-picks-badge">
                <img src="/mogu-picks-icon.png" alt="Mogu Picks" class="mogu-icon" />
              </span>
            )
          }
        </span>
        {
          ticketLabel && (
            <span class={`post-meta-label label-${ticketPrefix.toLowerCase()}`}>{ticketLabel}</span>
          )
        }
      </div>
      {
        showSourceCitation && (
          <a class="source-citation" href={post.data.sourceUrl} target="_blank" rel="noopener">
            <span class="source-citation-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="17"
                height="17"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M10 13a5 5 0 0 0 7.1.1l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1" />
                <path d="M14 11a5 5 0 0 0-7.1-.1l-2 2A5 5 0 0 0 12 20l1.1-1.1" />
              </svg>
            </span>
            <strong>{sourceCitationLabel}:</strong>
            <span class="source-citation-link-text">{sourceCitationText}</span>
          </a>
        )
      }
    </header>

    {
      postStatus.status !== 'published' && (
        <PostStatusBanner
          type={postStatus.status}
          lang="en"
          replacementHref={
            postStatus.replacementPost ? getLocalizedPostUrl(postStatus.replacementPost) : undefined
          }
          replacementUrl={replacementUrl ?? undefined}
          replacementTitle={postStatus.replacementPost?.data.title}
          replacementTicketId={postStatus.replacementTicketId}
        />
      )
    }

    {
      post.data.warnedByStage0 && post.data.warnReason && (
        <Stage0WarnBanner
          reason={post.data.warnReason}
          overrideComment={post.data.warnOverrideComment}
          lang="en"
        />
      )
    }

    {
      post.data.stage4Scores?.isDegraded && (
        <Stage4DegradedBanner stage4Scores={post.data.stage4Scores} lang="en" />
      )
    }

    {
      isBelowPublishBar(post.data.scores) && (
        <Sub8RefiningBanner composite={computeOverallComposite(post.data.scores) ?? 0} lang="en" />
      )
    }

    <TableOfContents lang="en" headings={headings} maxDepth={isLevelUp ? 2 : 3} />

    <div class="post-content">
      <Content />
    </div>

    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags-section">
          <span class="tags-label">
            <svg
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 13 13 20l-9-9V4h7l9 9Z" />
              <circle cx="8.5" cy="8.5" r="1.25" />
            </svg>
            Tags
          </span>
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <a href={`/en/tags/${tag}`} class="tag-chip">
                {tag}
              </a>
            ))}
          </div>
        </div>
      )
    }

    <ArticleActionArea
      title={post.data.title}
      slug={post.id}
      lang="en"
      postId={legacyPostId}
      ticketId={post.data.ticketId}
      postVersion={Number(postVersion)}
      readerRevision={postReaderRevision}
      pathname={Astro.url.pathname}
    />

    <section class="post-onward-zone" aria-label="Continue reading">
      {
        post.data.series ? (
          <SeriesNav currentSlug={post.id} allPosts={navigablePosts} lang="en" />
        ) : (
          <RelatedArticles
            currentSlug={post.id}
            currentTags={post.data.tags ?? []}
            allPosts={navigablePosts}
            lang="en"
          />
        )
      }

      <PrevNextNav currentSlug={post.id} allPosts={navigablePosts} lang="en" />
    </section>

    <ArticleTechnicalDetails
      translatedDate={post.data.translatedDate}
      translatedBy={post.data.translatedBy}
      scores={post.data.scores}
      authorshipNote={authorshipNote}
      isOriginalPost={isOriginalPost}
      postVersion={Number(postVersion)}
      historyHref={`https://github.com/chitienhsiehwork-ai/gu-log/commits/main/${post.filePath}`}
      lang="en"
    />

    <Giscus lang="en" />

    <footer class="post-footer">
      <a href="/en">← Back to home</a>
    </footer>
  </article>

  <AiPopup filePath={`${post.filePath}`} postTitle={post.data.title} lang="en" />
</BaseLayout>

<style>
  .post-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-meta-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-meta-label {
    font-size: 0.85rem;
    font-weight: 500;
    text-align: right;
  }

  .label-sd {
    color: var(--color-heading-sd, var(--color-badge-sd));
  }

  .label-gp {
    color: var(--color-badge-gp);
  }

  .label-mp {
    color: var(--color-mogu-orange);
  }

  .mogu-picks-badge {
    vertical-align: middle;
  }

  .mogu-icon {
    width: 24px;
    height: 24px;
    vertical-align: middle;
  }

  .meta-date {
    /* removed margin, using gap instead */
  }

  .post-tags-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .tags-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-chip {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tag-chip:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .post-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .post-onward-zone {
    margin-top: 2rem;
    padding-top: 0.25rem;
  }
</style>
