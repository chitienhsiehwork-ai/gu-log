---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TicketBadge from '../../../components/TicketBadge.astro';
import Toggle from '../../../components/Toggle.astro';
import PostStatusLabel from '../../../components/PostStatusLabel.astro';
import Pagination from '../../../components/Pagination.astro';
import { getListablePosts, getPostStatus } from '../../../utils/post-status';
import type { PostStatus } from '../../../utils/post-status';

export async function getStaticPaths({ paginate }: any) {
  const getTicketNumber = (ticketId: string | undefined) => {
    if (!ticketId) return 0;
    const match = ticketId.match(/\d+$/);
    return match ? parseInt(match[0]) : 0;
  };
  const allPostsFull = await getCollection('posts');
  const sdPosts = getListablePosts(allPostsFull, 'en')
    .filter((post) => post.data.ticketId?.startsWith('SD-'))
    .sort((a, b) => getTicketNumber(b.data.ticketId) - getTicketNumber(a.data.ticketId));
  return paginate(sdPosts, { pageSize: 20 });
}

const { page } = Astro.props;
const allPostsFull = await getCollection('posts');
const getTimelineStyle = (status: PostStatus) =>
  status === 'published' ? undefined : 'opacity: 0.6; filter: grayscale(0.22);';
---

<BaseLayout title="ShroomDog Original - All Posts" lang="en">
  <h1><img src="/gu-log-icon-trimmed.png" alt="" class="page-icon" /> ShroomDog Original</h1>
  <p class="page-subtitle">Original content by ShroomDog</p>
  <p class="post-count">{page.total} posts</p>

  <a href="/en" class="back-link">← Back to home</a>

  <section class="archive-list">
    {
      page.data.map((post: any) => {
        const status = getPostStatus(post, allPostsFull);
        return (
          <article class="post-preview" style={getTimelineStyle(status)}>
            <h3>
              <a href={`/en/posts/${post.slug}`}>
                {post.data.title}
                {status !== 'published' && <PostStatusLabel status={status} />}
              </a>
            </h3>
            <p class="post-meta">
              {post.data.ticketId && <TicketBadge ticketId={post.data.ticketId} />}
              {post.data.translatedDate || post.data.originalDate} · {post.data.source}
            </p>
            <Toggle title="Preview">
              <p>{post.data.summary}</p>
            </Toggle>
          </article>
        );
      })
    }
  </section>

  {page.data.length === 0 && <p class="empty-message">No original content yet. Stay tuned!</p>}

  <Pagination page={page} lang="en" />
</BaseLayout>

<style>
  h1 {
    color: var(--color-accent);
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .archive-list {
    margin-bottom: 2rem;
  }

  .post-preview {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-preview h3 {
    margin-bottom: 0.25rem;
  }

  .post-preview h3 a {
    color: var(--color-text);
  }

  .post-preview h3 a:hover {
    color: var(--color-accent);
  }

  .empty-message {
    padding: 2rem;
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
