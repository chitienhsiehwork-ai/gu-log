---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TicketBadge from '../../../components/TicketBadge.astro';
import Toggle from '../../../components/Toggle.astro';
import PostStatusLabel from '../../../components/PostStatusLabel.astro';
import { getListablePosts, getPostStatus } from '../../../utils/post-status';
import type { PostStatus } from '../../../utils/post-status';

// Helper: extract number from ticketId (e.g., "SP-16" → 16)
const getTicketNumber = (ticketId: string | undefined) => {
  if (!ticketId) return 0;
  const match = ticketId.match(/\d+$/);
  return match ? parseInt(match[0]) : 0;
};

// Get all SP posts, sorted by ticketId number descending
const allPostsFull = await getCollection('posts');
const spPosts = getListablePosts(allPostsFull, 'en')
  .filter((post) => post.data.ticketId?.startsWith('SP-'))
  .sort((a, b) => getTicketNumber(b.data.ticketId) - getTicketNumber(a.data.ticketId));
const getTimelineStyle = (status: PostStatus) =>
  status === 'published' ? undefined : 'opacity: 0.6; filter: grayscale(0.22);';
---

<BaseLayout title="ShroomDog Picks - All Posts" lang="en">
  <h1>📚 ShroomDog Picks</h1>
  <p class="page-subtitle">Long-form articles, translated and explained</p>
  <p class="post-count">{spPosts.length} posts</p>

  <a href="/en" class="back-link">← Back to home</a>

  <section class="archive-list">
    {
      spPosts.map((post) => {
        const status = getPostStatus(post, allPostsFull);
        return (
          <article class="post-preview" style={getTimelineStyle(status)}>
            <h3>
              <a href={`/en/posts/${post.slug}`}>
                {post.data.title}
                {status !== 'published' && <PostStatusLabel status={status} />}
              </a>
            </h3>
            <p class="post-meta">
              {post.data.ticketId && <TicketBadge ticketId={post.data.ticketId} />}
              {post.data.translatedDate || post.data.originalDate} · From {post.data.source}
            </p>
            <Toggle title="Preview">
              <p>{post.data.summary}</p>
            </Toggle>
          </article>
        );
      })
    }
  </section>
</BaseLayout>

<style>
  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .archive-list {
    margin-bottom: 2rem;
  }

  .post-preview {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-preview h3 {
    margin-bottom: 0.25rem;
  }

  .post-preview h3 a {
    color: var(--color-text);
  }

  .post-preview h3 a:hover {
    color: var(--color-accent);
  }
</style>
