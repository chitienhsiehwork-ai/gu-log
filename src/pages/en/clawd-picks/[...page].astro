---
import { getCollection } from 'astro:content';
import type { GetStaticPathsOptions } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TicketBadge from '../../../components/TicketBadge.astro';
import PostStatusLabel from '../../../components/PostStatusLabel.astro';
import Pagination from '../../../components/Pagination.astro';
import { getListablePosts, getPostStatus } from '../../../utils/post-status';
import type { PostStatus } from '../../../utils/post-status';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const getTicketNumber = (ticketId: string | undefined) => {
    if (!ticketId) return 0;
    const match = ticketId.match(/\d+$/);
    return match ? parseInt(match[0]) : 0;
  };
  const allPostsFull = await getCollection('posts');
  const cpPosts = getListablePosts(allPostsFull, 'en')
    .filter((post) => post.data.ticketId?.startsWith('CP-'))
    .sort((a, b) => getTicketNumber(b.data.ticketId) - getTicketNumber(a.data.ticketId));
  return paginate(cpPosts, { pageSize: 20 });
}

const { page } = Astro.props;
const allPostsFull = await getCollection('posts');
const getTimelineStyle = (status: PostStatus) =>
  status === 'published' ? undefined : 'opacity: 0.6; filter: grayscale(0.22);';
---

<BaseLayout title="Clawd Picks - All Posts" lang="en">
  <h1><img src="/clawd-picks-icon.png" alt="" class="page-icon" /> Clawd Picks</h1>
  <p class="page-subtitle">One tweet, translated every hour by Clawd</p>
  <p class="post-count">{page.total} posts</p>

  <a href="/en" class="back-link">← Back to home</a>

  <section class="archive-list">
    {
      page.data.map((pick) => {
        const status = getPostStatus(pick, allPostsFull);
        return (
          <article class="pick-preview" style={getTimelineStyle(status)}>
            <a href={`/en/posts/${pick.slug}`} class="pick-title">
              {pick.data.title}
              {status !== 'published' && <PostStatusLabel status={status} />}
            </a>
            <span class="pick-meta">
              {pick.data.ticketId && <TicketBadge ticketId={pick.data.ticketId} />}
              {pick.data.translatedDate || pick.data.originalDate} · {pick.data.source}
            </span>
          </article>
        );
      })
    }
  </section>

  <Pagination page={page} lang="en" />
</BaseLayout>

<style>
  .page-icon {
    width: 32px;
    height: 32px;
    vertical-align: middle;
    margin-right: 0.5rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .post-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .archive-list {
    margin-bottom: 2rem;
  }

  .pick-preview {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pick-title {
    display: block;
    color: var(--color-text);
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .pick-title:hover {
    color: var(--color-accent);
  }

  .pick-meta {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
</style>
