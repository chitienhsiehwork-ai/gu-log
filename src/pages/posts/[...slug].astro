---
import { getCollection, render } from 'astro:content';
import { getPostReaderRevision, getPostVersion } from '../../utils/post-versions';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import PrevNextNav from '../../components/PrevNextNav.astro';
import SeriesNav from '../../components/SeriesNav.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import PostStatusBanner from '../../components/PostStatusBanner.astro';
import Stage0WarnBanner from '../../components/Stage0WarnBanner.astro';
import Stage4DegradedBanner from '../../components/Stage4DegradedBanner.astro';
import Sub8RefiningBanner from '../../components/Sub8RefiningBanner.astro';
import { computeOverallComposite, isBelowPublishBar } from '../../utils/tribunal-scores';
import TicketBadge from '../../components/TicketBadge.astro';
import Giscus from '../../components/Giscus.astro';
import ShareButton from '../../components/ShareButton.astro';
import LoginCta from '../../components/LoginCta.astro';
import AiPopup from '../../components/AiPopup.astro';
import ReadStatusButton from '../../components/ReadStatusButton.astro';
import AiJudgeScore from '../../components/AiJudgeScore.astro';
import { getPostAuthorshipNote } from '../../utils/post-authorship-notes';
import { getNavigablePosts, resolvePostStatus } from '../../utils/post-status';
import { getLocalizedPostUrl } from '../../utils/post-urls';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const posts = allPosts.filter((post) => post.data.lang === 'zh-tw');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
      allPosts,
    },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const ticketId = post.data.ticketId;
const ticketPrefix = ticketId?.split('-')[0] || '';
const isMoguPicks = ticketId?.startsWith('MP-') ?? false;
const isLevelUp = ticketId?.startsWith('Lv-') ?? false;
const isShroomDogOriginal = ticketId?.startsWith('SD-') ?? false;
// SD/Lv are originals — the model signature is "written by", not "translated by".
const isOriginalPost = isLevelUp || isShroomDogOriginal;
const isChatGptShareSource = post.data.sourceUrl.startsWith('https://chatgpt.com/share/');
// Lv tutorials are originals, but when one is built on a real external source
// (not a self-referential gu-log link) the source should still be credited + linked.
const hasExternalSource =
  !!post.data.sourceUrl && !post.data.sourceUrl.includes('gu-log.vercel.app');
const showSourceCitation =
  (!isLevelUp && (!isShroomDogOriginal || isChatGptShareSource)) ||
  (isLevelUp && hasExternalSource);
const sourceCitationLabel = isLevelUp
  ? '參考來源'
  : isShroomDogOriginal && isChatGptShareSource
    ? '靈感來源'
    : '原文出處';
// Legacy Lv posts encoded the gu-log series name into `source`.
// The Lv badge already carries that context, so credit only the real source.
const sourceCitationText = post.data.source.replace(/^Level-Up 系列\s*[／/]\s*/, '');

// Reader-state records in the wild are keyed by the legacy entry id
// (filename incl. extension) — keep sending that exact value as postId.
const legacyPostId = post.filePath?.split('/').pop() ?? post.id;
const postVersion = getPostVersion(post.id);
const postReaderRevision = getPostReaderRevision(post.id);
const authorshipNote = getPostAuthorshipNote(post.id, 'zh-tw');
const postStatus = resolvePostStatus(post, allPosts);
const canonicalPostUrl = new URL(getLocalizedPostUrl(post), Astro.site).href;
const markdownUrl = `${canonicalPostUrl}.md`;
const replacementUrl = postStatus.replacementPost
  ? new URL(getLocalizedPostUrl(postStatus.replacementPost), Astro.site).href
  : null;
const navigablePosts = getNavigablePosts(allPosts, post);

const ticketLabels: Record<string, string> = {
  SD: 'ShroomDog Original',
  GP: 'Gu-log Picks',
  MP: 'Mogu Picks',
};
const ticketLabel = ticketLabels[ticketPrefix] || '';
---

<BaseLayout title={`${post.data.title} - gu-log`} markdownUrl={markdownUrl}>
  <article
    class="post"
    data-post-representation
    data-post-slug={post.id}
    data-post-lang={post.data.lang}
    data-post-status={postStatus.status}
    data-replacement-ticket-id={postStatus.replacementTicketId ?? ''}
    data-replacement-url={replacementUrl ?? ''}
  >
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta-row">
        <span class="post-meta-left">
          {ticketId && <TicketBadge ticketId={ticketId} />}
          <span class="meta-date">{post.data.translatedDate || post.data.originalDate}</span>
          {
            isMoguPicks && (
              <span class="mogu-picks-badge">
                <img src="/mogu-picks-icon.png" alt="Mogu Picks" class="mogu-icon" />
              </span>
            )
          }
        </span>
        {
          ticketLabel && (
            <span class={`post-meta-label label-${ticketPrefix.toLowerCase()}`}>{ticketLabel}</span>
          )
        }
      </div>
    </header>

    {
      postStatus.status !== 'published' && (
        <PostStatusBanner
          type={postStatus.status}
          lang="zh-tw"
          replacementHref={
            postStatus.replacementPost ? getLocalizedPostUrl(postStatus.replacementPost) : undefined
          }
          replacementUrl={replacementUrl ?? undefined}
          replacementTitle={postStatus.replacementPost?.data.title}
          replacementTicketId={postStatus.replacementTicketId}
        />
      )
    }

    {
      post.data.warnedByStage0 && post.data.warnReason && (
        <Stage0WarnBanner
          reason={post.data.warnReason}
          overrideComment={post.data.warnOverrideComment}
          lang="zh-tw"
        />
      )
    }

    {
      post.data.stage4Scores?.isDegraded && (
        <Stage4DegradedBanner stage4Scores={post.data.stage4Scores} lang="zh-tw" />
      )
    }

    {
      isBelowPublishBar(post.data.scores) && (
        <Sub8RefiningBanner
          composite={computeOverallComposite(post.data.scores) ?? 0}
          lang="zh-tw"
        />
      )
    }

    {
      showSourceCitation && (
        <div class="source-citation">
          <strong>{sourceCitationLabel}：</strong>
          <a href={post.data.sourceUrl} target="_blank" rel="noopener">
            {sourceCitationText}
          </a>
        </div>
      )
    }

    <TableOfContents lang="zh-tw" headings={headings} maxDepth={isLevelUp ? 2 : 3} />

    <div class="post-content">
      <Content />
    </div>

    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags-section">
          <span class="tags-label">🏷️ Tags</span>
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag-chip">
                {tag}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      ((post.data.translatedDate && post.data.translatedBy) || authorshipNote) && (
        <div class="translation-info">
          {post.data.translatedDate &&
            post.data.translatedBy &&
            (post.data.translatedBy.pipeline ? (
              <>
                <div>
                  {isOriginalPost ? '撰寫於' : '翻譯於'} {post.data.translatedDate}
                </div>
                {post.data.translatedBy.pipeline.map((step) => (
                  <div>
                    {step.role} by {step.model} ({step.harness})
                  </div>
                ))}
                {post.data.translatedBy.pipelineUrl && (
                  <div>
                    <a href={post.data.translatedBy.pipelineUrl} target="_blank" rel="noopener">
                      View pipeline script →
                    </a>
                  </div>
                )}
              </>
            ) : (
              <div>
                {isOriginalPost ? '撰寫於' : '翻譯於'} {post.data.translatedDate} by{' '}
                {post.data.translatedBy.model} ({post.data.translatedBy.harness})
              </div>
            ))}
          {authorshipNote && (
            <div class="authorship-note">
              <strong>作者推定：</strong>
              <span>{authorshipNote}</span>
            </div>
          )}
        </div>
      )
    }

    {post.data.scores && <AiJudgeScore scores={post.data.scores} lang="zh-tw" />}

    <ReadStatusButton
      slug={post.id}
      lang="zh-tw"
      postId={legacyPostId}
      ticketId={post.data.ticketId}
      postVersion={Number(postVersion)}
      readerRevision={postReaderRevision}
      pathname={Astro.url.pathname}
    />

    <ShareButton
      title={post.data.title}
      lang="zh-tw"
      postId={legacyPostId}
      ticketId={post.data.ticketId}
      postVersion={Number(postVersion)}
      pathname={Astro.url.pathname}
    />

    <LoginCta lang="zh-tw" />

    {
      post.data.series ? (
        <SeriesNav currentSlug={post.id} allPosts={navigablePosts} lang="zh-tw" />
      ) : (
        <RelatedArticles
          currentSlug={post.id}
          currentTags={post.data.tags ?? []}
          allPosts={navigablePosts}
          lang="zh-tw"
        />
      )
    }

    <PrevNextNav currentSlug={post.id} allPosts={navigablePosts} lang="zh-tw" />

    <Giscus lang="zh-tw" />

    <div class="post-version-info">
      <span class="version-badge">v{postVersion}</span>
      <a
        href={`https://github.com/chitienhsiehwork-ai/gu-log/commits/main/${post.filePath}`}
        target="_blank"
        rel="noopener"
        class="version-history-link"
      >
        查看編輯歷史 →
      </a>
    </div>

    <footer class="post-footer">
      <a href="/">← 返回首頁</a>
    </footer>
  </article>

  <AiPopup filePath={`${post.filePath}`} postTitle={post.data.title} lang="zh-tw" />
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-header h1 {
    margin-bottom: 0.5rem;
  }

  .post-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-meta-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-meta-label {
    font-size: 0.85rem;
    font-weight: 500;
    text-align: right;
  }

  .label-sd {
    color: var(--color-heading-sd, var(--color-badge-sd));
  }

  .label-gp {
    color: var(--color-badge-gp);
  }

  .label-mp {
    color: var(--color-mogu-orange);
  }

  .mogu-picks-badge {
    vertical-align: middle;
  }

  .mogu-icon {
    width: 24px;
    height: 24px;
    vertical-align: middle;
  }

  .meta-date {
    /* removed margin, using gap instead */
  }

  .post-tags-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .tags-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-chip {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tag-chip:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .post-content {
    margin: 1.5rem 0;
  }

  .post-content blockquote {
    font-style: normal;
    font-size: 1.1rem;
  }

  .post-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .translation-info {
    margin-top: 2rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-bg-secondary, rgba(0, 0, 0, 0.03));
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .translation-info .authorship-note {
    margin-top: 0.5rem;
  }

  .authorship-note strong {
    color: var(--color-text);
  }

  .post-version-info {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
  }

  .version-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background-color: var(--color-bg-secondary, rgba(0, 0, 0, 0.05));
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .version-history-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .version-history-link:hover {
    color: var(--color-accent);
  }
</style>
