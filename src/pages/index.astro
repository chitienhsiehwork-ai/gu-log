---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Toggle from '../components/Toggle.astro';
import TicketBadge from '../components/TicketBadge.astro';
import PostStatusLabel from '../components/PostStatusLabel.astro';
import { getListablePosts, getPostStatus, type PostStatus } from '../utils/post-status';

const allPostsFull = await getCollection('posts');
const allPosts = getListablePosts(allPostsFull, 'zh-tw');

// Helper: extract number from ticketId (e.g., "CP-11" → 11)
const getTicketNumber = (ticketId: string | undefined) => {
  if (!ticketId) return 0;
  const match = ticketId.match(/\d+$/);
  return match ? parseInt(match[0]) : 0;
};

const getTimelineStyle = (status: PostStatus) =>
  status === 'published' ? undefined : 'opacity: 0.6; filter: grayscale(0.22);';

// Sort by ticketId number descending (largest first = newest)
const sortByTicketNumber = (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
  getTicketNumber(b.data.ticketId) - getTicketNumber(a.data.ticketId);

// Filter and sort each category
const sdPosts = allPosts.filter((p) => p.data.ticketId?.startsWith('SD-')).sort(sortByTicketNumber);

const lvPosts = allPosts.filter((p) => p.data.ticketId?.startsWith('Lv-')).sort(sortByTicketNumber);

const spPosts = allPosts.filter((p) => p.data.ticketId?.startsWith('SP-')).sort(sortByTicketNumber);

const cpPosts = allPosts.filter((p) => p.data.ticketId?.startsWith('CP-')).sort(sortByTicketNumber);
---

<BaseLayout title="ShroomDog">
  {/* SP: ShroomDog Picks — 最頻繁更新 */}
  {
    spPosts.length > 0 && (
      <section class="posts-section sp-section">
        <h2>📚 ShroomDog Picks</h2>
        <p class="section-subtitle">ShroomDog 精選長文翻譯</p>

        {spPosts.slice(0, 3).map((post) => {
          const status = getPostStatus(post, allPostsFull);
          return (
            <article class="post-preview" style={getTimelineStyle(status)}>
              <h3>
                <a href={`/posts/${post.slug}`}>
                  {post.data.title}
                  {status !== 'published' && <PostStatusLabel status={status} />}
                </a>
              </h3>
              <p class="post-meta">
                {post.data.ticketId && <TicketBadge ticketId={post.data.ticketId} />}
                {post.data.translatedDate || post.data.originalDate} · 翻譯自 {post.data.source}
              </p>
              <Toggle title="摘要預覽">
                <p>{post.data.summary}</p>
              </Toggle>
            </article>
          );
        })}

        {spPosts.length > 3 && (
          <p class="view-all">
            <a href="/shroomdog-picks">查看全部 →</a>
          </p>
        )}
      </section>
    )
  }

  {/* CP: Clawd Picks */}
  {
    cpPosts.length > 0 && (
      <section class="clawd-picks-section" id="clawd-picks">
        <h2>
          <img src="/clawd-picks-icon.png" alt="" class="clawd-section-icon" /> Clawd Picks
        </h2>
        <p class="section-subtitle">Clawd 每 5 小時精選一則推文翻譯</p>

        {cpPosts.slice(0, 5).map((pick) => {
          const status = getPostStatus(pick, allPostsFull);
          return (
            <article class="pick-preview" style={getTimelineStyle(status)}>
              <a href={`/posts/${pick.slug}`}>
                {pick.data.title}
                {status !== 'published' && <PostStatusLabel status={status} />}
              </a>
              <span class="pick-meta">
                {pick.data.ticketId && <TicketBadge ticketId={pick.data.ticketId} />}
                {pick.data.translatedDate || pick.data.originalDate} · {pick.data.source}
              </span>
              {pick.data.summary && (
                <Toggle title="摘要預覽">
                  <p>{pick.data.summary}</p>
                </Toggle>
              )}
            </article>
          );
        })}

        {cpPosts.length > 5 && (
          <p class="view-all">
            <a href="/clawd-picks">查看全部 →</a>
          </p>
        )}
      </section>
    )
  }

  {/* SD: ShroomDog Original */}
  {
    sdPosts.length > 0 && (
      <section class="posts-section sd-section">
        <h2>
          <img src="/gu-log-icon-trimmed.png" alt="" class="section-icon" /> ShroomDog Original
        </h2>
        <p class="section-subtitle">ShroomDog 原創內容</p>

        {sdPosts.slice(0, 3).map((post) => {
          const status = getPostStatus(post, allPostsFull);
          return (
            <article class="post-preview" style={getTimelineStyle(status)}>
              <h3>
                <a href={`/posts/${post.slug}`}>
                  {post.data.title}
                  {status !== 'published' && <PostStatusLabel status={status} />}
                </a>
              </h3>
              <p class="post-meta">
                {post.data.ticketId && <TicketBadge ticketId={post.data.ticketId} />}
                {post.data.translatedDate || post.data.originalDate} · {post.data.source}
              </p>
              <Toggle title="摘要預覽">
                <p>{post.data.summary}</p>
              </Toggle>
            </article>
          );
        })}

        {sdPosts.length > 3 && (
          <p class="view-all">
            <a href="/shroomdog-originals">查看全部 →</a>
          </p>
        )}
      </section>
    )
  }

  {/* Lv: Level-Up */}
  {
    lvPosts.length > 0 && (
      <section class="posts-section lv-section">
        <h2>⚔️ Level-Up</h2>
        <p class="section-subtitle">互動式技術教學 — 用 RPG 爬塔風格學技術</p>

        {lvPosts.slice(0, 3).map((post) => {
          const status = getPostStatus(post, allPostsFull);
          return (
            <article class="post-preview" style={getTimelineStyle(status)}>
              <h3>
                <a href={`/posts/${post.slug}`}>
                  {post.data.title}
                  {status !== 'published' && <PostStatusLabel status={status} />}
                </a>
              </h3>
              <p class="post-meta">
                {post.data.ticketId && <TicketBadge ticketId={post.data.ticketId} />}
                {post.data.translatedDate || post.data.originalDate} · {post.data.source}
              </p>
              <Toggle title="摘要預覽">
                <p>{post.data.summary}</p>
              </Toggle>
            </article>
          );
        })}

        {lvPosts.length > 3 && (
          <p class="view-all">
            <a href="/level-up">查看全部 →</a>
          </p>
        )}
      </section>
    )
  }
</BaseLayout>

<style>
  .site-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    vertical-align: middle;
    margin-right: 0.5rem;
  }

  .intro {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .author-note {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .posts-section,
  .clawd-picks-section {
    margin-bottom: 1.5rem;
    padding-top: 1.25rem;
  }

  /* First section has no divider */
  .posts-section:first-child,
  .sp-section {
    padding-top: 0;
  }

  /* Short centered divider between sections */
  .clawd-picks-section::before,
  .sd-section::before,
  .lv-section::before {
    content: '';
    display: block;
    width: 48px;
    height: 1.5px;
    background: var(--color-border);
    margin: 0 auto 1.25rem;
    border-radius: 1px;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-top: -0.25rem;
    margin-bottom: 0.5rem;
  }

  .sd-section h2 {
    color: var(--color-heading-sd, var(--color-badge-sd));
  }

  .lv-section h2 {
    color: var(--color-badge-lv);
  }

  .sp-section h2 {
    color: var(--color-heading-sp, var(--color-badge-sp));
  }

  .clawd-picks-section h2 {
    color: var(--color-clawd-orange);
  }

  .clawd-section-icon,
  .section-icon {
    width: 24px;
    height: 24px;
    vertical-align: middle;
    border-radius: 22%;
  }

  /* Tighter meta + toggle gap on index page */
  .post-preview .post-meta {
    margin-bottom: 0;
  }

  .post-preview :global(.toggle-container) {
    margin: 0.1rem 0 0;
  }

  .post-preview :global(.toggle-header) {
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
  }

  .pick-preview {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-divider);
    font-size: 0.9rem;
  }

  .pick-preview a {
    color: var(--color-text);
  }

  .pick-preview a:hover {
    color: var(--color-accent);
  }

  .pick-meta {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin-bottom: 0;
  }

  .pick-preview :global(.toggle-container) {
    margin: 0.1rem 0 0;
  }

  .post-preview {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-divider);
  }

  .post-preview h3 {
    margin-bottom: 0.15rem;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .post-preview h3 a {
    color: var(--color-text);
  }

  .post-preview h3 a:hover {
    color: var(--color-accent);
  }

  .view-all {
    margin-top: 0.75rem;
    text-align: right;
  }

  .view-all a {
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  .view-all a:hover {
    text-decoration: underline;
  }
</style>
