---
import BaseLayout from '../layouts/BaseLayout.astro';
import glossaryData from '../data/glossary.json';

const glossary = [...glossaryData].sort((a, b) => a.term.localeCompare(b.term));

const categories: { id: string; label: string }[] = [
  { id: 'all', label: '全部' },
  { id: 'tools', label: '工具' },
  { id: 'concepts', label: '概念' },
  { id: 'methods', label: '方法' },
  { id: 'platforms', label: '平台' },
];
---

<BaseLayout title="詞彙表 - gu-log" lang="zh-tw">
  <article class="glossary-page">
    <header>
      <h1>📖 詞彙表</h1>
      <p class="glossary-intro">AI 領域術語變化很快，這裡整理了本站常出現的詞彙。</p>
    </header>

    <div class="glossary-controls">
      <input
        type="search"
        id="glossary-search"
        class="glossary-search"
        placeholder="搜尋術語..."
        aria-label="搜尋術語"
      />
      <div class="category-pills" role="group" aria-label="分類篩選">
        {
          categories.map((cat) => (
            <button
              class="category-pill"
              data-category={cat.id}
              aria-pressed={cat.id === 'all' ? 'true' : 'false'}
            >
              {cat.label}
            </button>
          ))
        }
      </div>
    </div>

    <p class="glossary-count" id="glossary-count">{glossary.length} 個術語</p>

    <div class="glossary-list" id="glossary-list">
      {
        glossary.map((item) => (
          <div
            class="glossary-item"
            id={item.term.toLowerCase().replace(/\s+/g, '-')}
            data-term={item.term.toLowerCase()}
            data-en={item.en.toLowerCase()}
            data-definition={item.definition.toLowerCase()}
            data-category={item.category}
          >
            <h2 class="glossary-term">
              {item.term}
              {item.en !== item.term && <span class="glossary-en">({item.en})</span>}
              <span class="category-tag">{item.category}</span>
            </h2>
            <p class="glossary-definition">{item.definition}</p>
            {item.related && item.related.length > 0 && (
              <div class="glossary-related">
                相關：
                {item.related.map((rel, i) => (
                  <span>
                    <a href={`#${rel.toLowerCase().replace(/\s+/g, '-')}`}>{rel}</a>
                    {i < item.related.length - 1 && '、'}
                  </span>
                ))}
              </div>
            )}
            {item.definedIn && item.definedIn.length > 0 && (
              <div class="glossary-defined-in">
                <span class="defined-in-label">詳細說明於：</span>
                {item.definedIn.map((post: { slug: string; title: string }, i: number) => (
                  <span>
                    <a href={`/posts/${post.slug}`}>{post.title}</a>
                    {i < item.definedIn.length - 1 && '、'}
                  </span>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </div>

    <p class="glossary-empty" id="glossary-empty" style="display:none">沒有符合的術語。</p>

    <footer class="glossary-footer">
      <a href="/">← 返回首頁</a>
    </footer>
  </article>
</BaseLayout>

<script>
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
  const items = document.querySelectorAll<HTMLElement>('.glossary-item');
  const countEl = document.getElementById('glossary-count');
  const emptyEl = document.getElementById('glossary-empty');

  let activeCategory = 'all';

  function filterItems() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    items.forEach((item) => {
      const matchesCategory = activeCategory === 'all' || item.dataset.category === activeCategory;
      const matchesSearch =
        !query ||
        item.dataset.term?.includes(query) ||
        item.dataset.en?.includes(query) ||
        item.dataset.definition?.includes(query);

      const show = matchesCategory && matchesSearch;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countEl) countEl.textContent = `${visible} 個術語`;
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
  }

  searchInput?.addEventListener('input', filterItems);

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      activeCategory = pill.dataset.category ?? 'all';
      pills.forEach((p) => p.setAttribute('aria-pressed', 'false'));
      pill.setAttribute('aria-pressed', 'true');
      filterItems();
    });
  });
</script>

<style>
  .glossary-page {
    max-width: 680px;
    margin: 0 auto;
  }

  .glossary-intro {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .glossary-controls {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .glossary-search {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.95rem;
    box-sizing: border-box;
  }

  .glossary-search:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .glossary-search::placeholder {
    color: var(--color-text-muted);
  }

  .category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .category-pill {
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .category-pill:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .category-pill[aria-pressed='true'] {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .glossary-count {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .glossary-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .glossary-item {
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border-radius: 6px;
    border-left: 3px solid var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
    border-left: 3px solid var(--color-accent);
  }

  .glossary-term {
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
    color: var(--color-text);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .glossary-en {
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .category-tag {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-muted);
    background: var(--color-border);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    margin-left: auto;
    white-space: nowrap;
  }

  .glossary-definition {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 0.25rem;
  }

  .glossary-related {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .glossary-related a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .glossary-related a:hover {
    text-decoration: underline;
  }

  .glossary-defined-in {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
  }

  .defined-in-label {
    color: var(--color-text-muted);
  }

  .glossary-defined-in a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .glossary-defined-in a:hover {
    text-decoration: underline;
  }

  .glossary-empty {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  .glossary-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
</style>
