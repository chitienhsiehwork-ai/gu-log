---
import BaseLayout from '../layouts/BaseLayout.astro';
import glossaryData from '../data/glossary.json';

const glossary = [...glossaryData].sort((a, b) => a.term.localeCompare(b.term));

const categories: { id: string; label: string }[] = [
  { id: 'all', label: '全部' },
  { id: 'tools', label: '工具' },
  { id: 'concepts', label: '概念' },
  { id: 'methods', label: '方法' },
  { id: 'platforms', label: '平台' },
];

const categoryLabel: Record<string, string> = {
  tools: '工具',
  concepts: '概念',
  methods: '方法',
  platforms: '平台',
};

// Group by first letter
const grouped: { letter: string; items: typeof glossary }[] = [];
let currentLetter = '';
for (const item of glossary) {
  const letter = item.term[0].toUpperCase();
  if (letter !== currentLetter) {
    currentLetter = letter;
    grouped.push({ letter, items: [item] });
  } else {
    grouped[grouped.length - 1].items.push(item);
  }
}

const allLetters = grouped.map((g) => g.letter);
---

<BaseLayout title="詞彙表 - gu-log" lang="zh-tw">
  <article class="glossary-page">
    <header>
      <h1>📖 詞彙表</h1>
      <p class="glossary-intro">本站常出現的 AI 術語。點術語名稱可複製連結。</p>
    </header>

    <div class="glossary-controls">
      <input
        type="search"
        id="glossary-search"
        class="glossary-search"
        placeholder="搜尋術語..."
        aria-label="搜尋術語"
      />
      <div class="controls-row">
        <div class="category-pills" role="group" aria-label="分類篩選">
          {
            categories.map((cat) => (
              <button
                class="category-pill"
                data-category={cat.id}
                aria-pressed={cat.id === 'all' ? 'true' : 'false'}
              >
                {cat.label}
              </button>
            ))
          }
        </div>
        <span class="glossary-count" id="glossary-count">{glossary.length} 個術語</span>
      </div>
    </div>

    {/* Alphabet jump bar */}
    <nav class="alpha-bar" aria-label="字母索引">
      {allLetters.map((l) => (
        <a href={`#letter-${l}`} class="alpha-link">{l}</a>
      ))}
    </nav>

    <div id="glossary-list">
      {
        grouped.map((group) => (
          <section class="letter-section" data-letter={group.letter} id={`letter-${group.letter}`}>
            <h2 class="letter-heading">{group.letter}</h2>
            <dl class="section-list">
              {group.items.map((item) => (
                <div
                  class="glossary-entry"
                  id={item.term.toLowerCase().replace(/\s+/g, '-')}
                  data-term={item.term.toLowerCase()}
                  data-en={item.en.toLowerCase()}
                  data-definition={item.definition.toLowerCase()}
                  data-category={item.category}
                >
                  <dt>
                    <a href={`#${item.term.toLowerCase().replace(/\s+/g, '-')}`} class="term-link">
                      {item.term}
                    </a>
                    {item.en !== item.term && <span class="term-en">{item.en}</span>}
                    <span class={`term-cat cat-${item.category}`}>{categoryLabel[item.category] || item.category}</span>
                  </dt>
                  <dd>
                    <p class="term-def">{item.definition}</p>
                    {(item.related?.length > 0 || item.definedIn?.length > 0) && (
                      <p class="term-meta">
                        {item.related?.length > 0 && (
                          <span class="meta-links">
                            →{' '}
                            {item.related.map((rel, i) => (
                              <span>
                                <a href={`#${rel.toLowerCase().replace(/\s+/g, '-')}`}>{rel}</a>
                                {i < item.related.length - 1 && '、'}
                              </span>
                            ))}
                          </span>
                        )}
                        {item.definedIn?.length > 0 && (
                          <span class="meta-posts">
                            {' '}| 文章：{' '}
                            {item.definedIn.map((post: { slug: string; title: string }, i: number) => (
                              <span>
                                <a href={`/posts/${post.slug}`}>{post.title}</a>
                                {i < item.definedIn.length - 1 && '、'}
                              </span>
                            ))}
                          </span>
                        )}
                      </p>
                    )}
                  </dd>
                </div>
              ))}
            </dl>
          </section>
        ))
      }
    </div>

    <p class="glossary-empty" id="glossary-empty" style="display:none">沒有符合的術語。</p>

    <footer class="glossary-footer">
      <a href="/">← 返回首頁</a>
    </footer>
  </article>
</BaseLayout>

<script>
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
  const entries = document.querySelectorAll<HTMLElement>('.glossary-entry');
  const sections = document.querySelectorAll<HTMLElement>('.letter-section');
  const countEl = document.getElementById('glossary-count');
  const emptyEl = document.getElementById('glossary-empty');

  let activeCategory = 'all';

  function filterItems() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    entries.forEach((entry) => {
      const matchesCategory = activeCategory === 'all' || entry.dataset.category === activeCategory;
      const matchesSearch =
        !query ||
        entry.dataset.term?.includes(query) ||
        entry.dataset.en?.includes(query) ||
        entry.dataset.definition?.includes(query);

      const show = matchesCategory && matchesSearch;
      entry.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    sections.forEach((section) => {
      const hasVisible = Array.from(section.querySelectorAll('.glossary-entry')).some(
        (e) => (e as HTMLElement).style.display !== 'none'
      );
      section.style.display = hasVisible ? '' : 'none';
    });

    if (countEl) countEl.textContent = `${visible} 個術語`;
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
  }

  searchInput?.addEventListener('input', filterItems);

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      activeCategory = pill.dataset.category ?? 'all';
      pills.forEach((p) => p.setAttribute('aria-pressed', 'false'));
      pill.setAttribute('aria-pressed', 'true');
      filterItems();
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('.term-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const url = new URL(link.href);
      navigator.clipboard.writeText(url.toString());
      history.replaceState(null, '', url.hash);
      link.classList.add('copied');
      setTimeout(() => link.classList.remove('copied'), 1200);
    });
  });
</script>

<style>
  .glossary-page {
    max-width: 760px;
    margin: 0 auto;
  }

  .glossary-intro {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  /* Controls */
  .glossary-controls {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .glossary-search {
    width: 100%;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.9rem;
    box-sizing: border-box;
  }

  .glossary-search:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .glossary-search::placeholder {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .controls-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .category-pill {
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .category-pill:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .category-pill[aria-pressed='true'] {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .glossary-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    opacity: 0.6;
  }

  /* Alphabet jump bar */
  .alpha-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem;
    padding: 0.4rem 0;
    margin-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .alpha-link {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    transition: all 0.1s;
  }

  .alpha-link:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  /* Letter sections */
  .letter-section {
    scroll-margin-top: 1rem;
  }

  .letter-heading {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-accent);
    margin: 0.75rem 0 0 0;
    padding-bottom: 0.2rem;
    border-bottom: 2px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    opacity: 0.9;
  }

  /* Entries */
  .section-list {
    margin: 0;
    padding: 0;
  }

  .glossary-entry {
    padding: 0.45rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
  }

  .glossary-entry:last-child {
    border-bottom: none;
  }

  dt {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .term-link {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .term-link:hover {
    color: var(--color-accent);
  }

  .term-link.copied::after {
    content: ' ✓ copied';
    color: var(--color-accent);
    font-size: 0.65rem;
    font-weight: 400;
  }

  .term-en {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 400;
    opacity: 0.7;
  }

  /* Inline category badges */
  .term-cat {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0.08rem 0.35rem;
    border-radius: 3px;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cat-tools {
    color: #f0a050;
    background: color-mix(in srgb, #f0a050 15%, transparent);
  }

  .cat-concepts {
    color: #60a5fa;
    background: color-mix(in srgb, #60a5fa 15%, transparent);
  }

  .cat-methods {
    color: #c084fc;
    background: color-mix(in srgb, #c084fc 15%, transparent);
  }

  .cat-platforms {
    color: #34d399;
    background: color-mix(in srgb, #34d399 15%, transparent);
  }

  dd {
    margin: 0.1rem 0 0 0;
  }

  .term-def {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0;
  }

  .term-meta {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin: 0.1rem 0 0 0;
    opacity: 0.55;
  }

  .term-meta a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .term-meta a:hover {
    text-decoration: underline;
    opacity: 1;
  }

  .glossary-empty {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    padding: 1rem 0;
  }

  .glossary-footer {
    margin-top: 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }

  /* Desktop: wider + two-column for sections with many items */
  @media (min-width: 768px) {
    .glossary-page {
      max-width: 820px;
    }
  }
</style>
