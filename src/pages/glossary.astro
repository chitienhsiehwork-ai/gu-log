---
import BaseLayout from '../layouts/BaseLayout.astro';
import glossaryData from '../data/glossary.json';

const glossary = [...glossaryData].sort((a, b) => a.term.localeCompare(b.term));

const categories: { id: string; label: string }[] = [
  { id: 'all', label: '全部' },
  { id: 'tools', label: '工具' },
  { id: 'concepts', label: '概念' },
  { id: 'methods', label: '方法' },
  { id: 'platforms', label: '平台' },
];

const categoryEmoji: Record<string, string> = {
  tools: '🔧',
  concepts: '💡',
  methods: '📐',
  platforms: '🌐',
};
---

<BaseLayout title="詞彙表 - gu-log" lang="zh-tw">
  <article class="glossary-page">
    <header>
      <h1>📖 詞彙表</h1>
      <p class="glossary-intro">本站常出現的 AI 術語。點術語名稱可複製連結。</p>
    </header>

    <div class="glossary-controls">
      <input
        type="search"
        id="glossary-search"
        class="glossary-search"
        placeholder="搜尋術語..."
        aria-label="搜尋術語"
      />
      <div class="category-pills" role="group" aria-label="分類篩選">
        {
          categories.map((cat) => (
            <button
              class="category-pill"
              data-category={cat.id}
              aria-pressed={cat.id === 'all' ? 'true' : 'false'}
            >
              {cat.label}
            </button>
          ))
        }
      </div>
    </div>

    <p class="glossary-count" id="glossary-count">{glossary.length} 個術語</p>

    <dl class="glossary-list" id="glossary-list">
      {
        glossary.map((item) => (
          <div
            class="glossary-entry"
            id={item.term.toLowerCase().replace(/\s+/g, '-')}
            data-term={item.term.toLowerCase()}
            data-en={item.en.toLowerCase()}
            data-definition={item.definition.toLowerCase()}
            data-category={item.category}
          >
            <dt>
              <a href={`#${item.term.toLowerCase().replace(/\s+/g, '-')}`} class="term-link">
                {item.term}
              </a>
              {item.en !== item.term && <span class="term-en">{item.en}</span>}
              <span class="term-cat">{categoryEmoji[item.category] || '📌'}</span>
            </dt>
            <dd>
              <p class="term-def">{item.definition}</p>
              {(item.related?.length > 0 || item.definedIn?.length > 0) && (
                <p class="term-meta">
                  {item.related?.length > 0 && (
                    <span class="meta-links">
                      →{' '}
                      {item.related.map((rel, i) => (
                        <span>
                          <a href={`#${rel.toLowerCase().replace(/\s+/g, '-')}`}>{rel}</a>
                          {i < item.related.length - 1 && '、'}
                        </span>
                      ))}
                    </span>
                  )}
                  {item.definedIn?.length > 0 && (
                    <span class="meta-posts">
                      {' '}📄{' '}
                      {item.definedIn.map((post: { slug: string; title: string }, i: number) => (
                        <span>
                          <a href={`/posts/${post.slug}`}>{post.title}</a>
                          {i < item.definedIn.length - 1 && '、'}
                        </span>
                      ))}
                    </span>
                  )}
                </p>
              )}
            </dd>
          </div>
        ))
      }
    </dl>

    <p class="glossary-empty" id="glossary-empty" style="display:none">沒有符合的術語。</p>

    <footer class="glossary-footer">
      <a href="/">← 返回首頁</a>
    </footer>
  </article>
</BaseLayout>

<script>
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
  const items = document.querySelectorAll<HTMLElement>('.glossary-entry');
  const countEl = document.getElementById('glossary-count');
  const emptyEl = document.getElementById('glossary-empty');

  let activeCategory = 'all';

  function filterItems() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    items.forEach((item) => {
      const matchesCategory = activeCategory === 'all' || item.dataset.category === activeCategory;
      const matchesSearch =
        !query ||
        item.dataset.term?.includes(query) ||
        item.dataset.en?.includes(query) ||
        item.dataset.definition?.includes(query);

      const show = matchesCategory && matchesSearch;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countEl) countEl.textContent = `${visible} 個術語`;
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
  }

  searchInput?.addEventListener('input', filterItems);

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      activeCategory = pill.dataset.category ?? 'all';
      pills.forEach((p) => p.setAttribute('aria-pressed', 'false'));
      pill.setAttribute('aria-pressed', 'true');
      filterItems();
    });
  });

  // Click term to copy anchor link
  document.querySelectorAll<HTMLAnchorElement>('.term-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const url = new URL(link.href);
      navigator.clipboard.writeText(url.toString());
      history.replaceState(null, '', url.hash);
      link.classList.add('copied');
      setTimeout(() => link.classList.remove('copied'), 1000);
    });
  });
</script>

<style>
  .glossary-page {
    max-width: 640px;
    margin: 0 auto;
  }

  .glossary-intro {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }

  /* Controls */
  .glossary-controls {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .glossary-search {
    width: 100%;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.9rem;
    box-sizing: border-box;
  }

  .glossary-search:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .glossary-search::placeholder {
    color: var(--color-text-muted);
  }

  .category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .category-pill {
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .category-pill:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .category-pill[aria-pressed='true'] {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .glossary-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  /* Definition list — dictionary style */
  .glossary-list {
    margin: 0;
    padding: 0;
  }

  .glossary-entry {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .glossary-entry:last-child {
    border-bottom: none;
  }

  dt {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .term-link {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .term-link:hover {
    color: var(--color-accent);
  }

  .term-link.copied {
    color: var(--color-accent);
  }

  .term-en {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .term-cat {
    font-size: 0.7rem;
    margin-left: auto;
  }

  dd {
    margin: 0.2rem 0 0 0;
  }

  .term-def {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
  }

  .term-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0.2rem 0 0 0;
    opacity: 0.7;
  }

  .term-meta a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .term-meta a:hover {
    text-decoration: underline;
  }

  .glossary-empty {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    padding: 1rem 0;
  }

  .glossary-footer {
    margin-top: 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }
</style>
