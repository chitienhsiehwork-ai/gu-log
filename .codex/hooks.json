{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/scripts/detect-env.sh\" --runtime codex --context",
            "timeout": 10,
            "statusMessage": "Detecting gu-log agent environment"
          }
        ]
      }
    ]
  }
}
