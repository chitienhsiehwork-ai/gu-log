#!/usr/bin/env bash
# sp-pipeline — backwards-compat shim.
#
# The canonical entry point is now `gp-pipeline` (Gu-log Picks, matching the
# blog brand). This shim is retained forever so existing callers — VPS Clawd
# automation, scripts/sp-pipeline.sh, older playbooks, and muscle memory —
# keep working with no behaviour change. It simply execs gp-pipeline next to it.
#
# Removal policy: do not delete. A one-line exec wrapper is free; deleting it
# breaks unknown callers. The ticket prefix and post slug also stay `SP` / `sp-`
# on purpose, so the legacy name still reads correctly.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$DIR/gp-pipeline" "$@"
