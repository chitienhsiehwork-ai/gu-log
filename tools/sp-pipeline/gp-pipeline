#!/usr/bin/env bash
# gp-pipeline — self-compiling wrapper around the Go binary.
#
# "GP" = Gu-log Picks, matching the blog's brand. This is the canonical entry
# point; `sp-pipeline` (next to this file) is a backwards-compat shim that
# execs straight into here, so existing callers (VPS Clawd automation,
# scripts/sp-pipeline.sh, older playbooks) keep working unchanged.
#
# First call on a fresh checkout builds the binary into ./bin/; subsequent calls
# reuse it. Go's incremental build cache makes the "is the binary stale?" check
# effectively free. This exists so that CCC (Cloud Claude Code) spawning a brand
# new sandbox does not need a prebuilt binary checked into git — just run:
#
#   tools/sp-pipeline/gp-pipeline run <tweet_url>
#
# and the first call takes ~3 seconds cold, everything after that is instant.
#
# NOTE: the implementation directory keeps its historical name
# (tools/sp-pipeline/) and Go module path on purpose — renaming a 40-file Go
# module is pure churn with no user-visible payoff. The brand rename lives at
# the command surface (this wrapper + the cobra command name + docs). The ticket
# prefix and post filename slug also stay `SP` / `sp-` by design.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="$DIR/bin/gp-pipeline"
PKG="./cmd/sp-pipeline"
BUILD_FLAGS=(-trimpath -ldflags=-s\ -w)

need_rebuild() {
  if [ ! -x "$BIN" ]; then
    return 0
  fi
  # Any source file newer than the binary triggers a rebuild. `-newer` is a
  # POSIX find primary so this works on both GNU and BSD find.
  if find "$DIR" -name '*.go' -newer "$BIN" -print 2>/dev/null | grep -q .; then
    return 0
  fi
  if [ "$DIR/go.mod" -nt "$BIN" ] || [ "$DIR/go.sum" -nt "$BIN" ]; then
    return 0
  fi
  return 1
}

if need_rebuild; then
  if ! command -v go >/dev/null 2>&1; then
    printf 'gp-pipeline: "go" not found on PATH — install Go >= 1.24 or point at a binary in %s\n' "$BIN" >&2
    exit 127
  fi
  mkdir -p "$DIR/bin"
  (cd "$DIR" && go build "${BUILD_FLAGS[@]}" -o "$BIN" "$PKG")
fi

exec "$BIN" "$@"
