[Unit]
Description=Tribunal Quota-Aware Loop (gu-log)
After=network-online.target

[Service]
Type=simple
# Local-only deployment config provides GU_LOG_DIR and USAGE_MONITOR. systemd
# `$$` passes a literal `$` to bash so values expand only at runtime.
EnvironmentFile=%h/.config/gu-log/tribunal.env
Environment=TRIBUNAL_DEPLOYED_MODE=1
Environment=TRIBUNAL_STRICT_ROLE_PROVIDERS=1
Environment=GP_WRITER_MODE=cli
ExecStart=/bin/bash -c ': "$${GU_LOG_DIR:?Missing GU_LOG_DIR in tribunal.env}"; : "$${USAGE_MONITOR:?Missing USAGE_MONITOR in tribunal.env}"; test -x "$$USAGE_MONITOR" || { echo "USAGE_MONITOR is not executable: $$USAGE_MONITOR" >&2; exit 78; }; cd "$$GU_LOG_DIR" && exec bash scripts/cc-tribunal-loop-wrapper.sh --workers 1'
Restart=on-failure
RestartSec=60
Environment=TZ=Asia/Taipei

# Graceful stop (see OpenSpec: tribunal-graceful-run-control)
# KillMode=mixed — SIGTERM goes to main process (wrapper→loop) only; the
# tribunal.sh subprocess is NOT killed and is allowed to finish
# the current article. The loop's trap sets stop_requested and exits
# cleanly at the next safe boundary.
KillMode=mixed
KillSignal=SIGTERM
# Worst case: article is in the middle of rewrite + build + frontmatter
# write. Allow up to 60min before SIGKILL.
TimeoutStopSec=3600

# Resource limits — sized for --workers 1 (overnight / light mode).
# A single worker peaks ~400MB (tribunal-writer + pnpm build + claude CLI),
# supervisor + shared state ~200MB. 4G cap kept (rather than shrinking to
# 1G or 2G) so scaling back up to 2–5 workers via `--workers N` only needs
# the ExecStart line flipped, no unit-level retuning. CPUQuota 200% also
# kept for the same reason; a single worker won't burn more than ~50%
# steady-state anyway.
#
# History: MemoryMax was bumped from 2G → 4G in PR #159 (2026-04-24) after
# a 5-worker OOM kill on the 2G cap; the root cause (rc=2 tight re-dispatch
# loop) is also fixed in that PR. The 4G headroom stays.
CPUQuota=200%
MemoryMax=4G

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tribunal-loop

[Install]
WantedBy=default.target
