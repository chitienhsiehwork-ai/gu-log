dist/
# generated types
.astro/

# dependencies
node_modules/
package-lock.json

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# local config/overrides
*.local.*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# ralph loop runtime logs & artifacts
.ralph/
logs/
scripts/clawd-picks.log
scripts/.x-cookies.json
.fetch-tweets.sh
.ralph-script.sh

# playwright cli generated files
.playwright-cli/
.playwright-mcp/

# Python cache
scripts/__pycache__/

# Playwright
playwright-report/
test-results/
.lighthouseci/
quality/lighthouse-reports/*.html
quality/lighthouse-reports/*.json
quality/lighthouse-reports/manifest.json
!quality/lighthouse-reports/.gitkeep

# Coverage report artifacts (keep baseline and history)
quality/coverage/
api/node_modules/
api/dist/

# Mermaid visual check screenshots (temporary)
.mermaid-screenshots/
.vercel
monocart-report/

tmp/
.ralph/runs/

# Local notes (not tracked)
*.local.md

# Tribunal daemon workspace (separate clone to avoid git dirty conflicts)
.tribunal-workspace/

# Score loop runtime artifacts (daemon writes these, not tracked)
.score-loop/raw/
.score-loop/logs/

# Tribunal v2 in-progress state files (saved by pipeline.onProgress)
# and completion records moved there by `markCompleted`. Both are VM-local
# audit data — a `git add -A` during Clawd's auto-publish flow would
# otherwise sweep these into article commits and flood main with noise.
# The pipeline's own per-stage `git commit` messages on the tribunal side
# branch already serve as the canonical audit trail.
.score-loop/progress/*.json
.score-loop/progress/completed/*.json
# Exception: the three cp-290 e2e smoke tests committed in PR #124 as
# illustrative reference data. These are intentionally tracked.
!.score-loop/progress/completed/cp-290-e2e-smoke-*.json

# Dedup guard cache (auto-generated)
scripts/.dedup-cache.json

# Throwaway experiment outputs (scripts/experiments/*)
.results/

# Backend repo (nested clone for local debug)
gu-log-api/

# pnpm store (local dev)
.pnpm-store/

# sp-pipeline Go binary (self-compiling wrapper rebuilds on demand)
tools/sp-pipeline/bin/
