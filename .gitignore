scripts/__pycache__/

# Playwright
playwright-report/
test-results/
.lighthouseci/
quality/lighthouse-reports/*.html
quality/lighthouse-reports/*.json
quality/lighthouse-reports/manifest.json
!quality/lighthouse-reports/.gitkeep

# Coverage report artifacts (keep baseline and history)
quality/coverage/
api/node_modules/
api/dist/

# Mermaid visual check screenshots (temporary)
.mermaid-screenshots/
.vercel
monocart-report/

tmp/
.ralph/runs/

# Local notes (not tracked)
*.local.md

# Tribunal daemon workspace (separate clone to avoid git dirty conflicts)
.tribunal-workspace/

# Score loop runtime artifacts (daemon writes these, not tracked)
.score-loop/raw/
.score-loop/logs/

# Tribunal v2 in-progress state files (saved by pipeline.onProgress)
# — completed/ subdir IS tracked for the audit trail, so exception follows.
.score-loop/progress/*.json
!.score-loop/progress/completed/

# Dedup guard cache (auto-generated)
scripts/.dedup-cache.json

# Backend repo (nested clone for local debug)
gu-log-api/

# pnpm store (local dev)
.pnpm-store/

# sp-pipeline Go binary (self-compiling wrapper rebuilds on demand)
tools/sp-pipeline/bin/
