{
  "env": {
    "CLAUDE_CODE_FORK_SUBAGENT": "1"
  },
  "permissions": {
    "deny": ["AskUserQuestion"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ]
  }
}
