{
  "name": "gu-log",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/build-version-manifest.mjs && node scripts/build-reader-revision-manifest.mjs",
    "build": "astro build",
    "postbuild": "node scripts/build-post-markdown.mjs && node scripts/verify-canonical-public-output.mjs",
    "build:post-markdown": "node scripts/build-post-markdown.mjs",
    "verify:canonical-public-output": "node scripts/verify-canonical-public-output.mjs",
    "verify:post-markdown-deployment": "node scripts/verify-post-markdown-deployment.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "pnpm exec playwright test",
    "test:ui": "pnpm exec playwright test --ui",
    "test:toc": "pnpm exec playwright test tests/toc.spec.ts",
    "test:visual": "node scripts/visual-test.mjs",
    "test:search": "node scripts/search-test.mjs",
    "test:search-relevance": "pnpm exec vitest run tests/search-relevance.test.ts",
    "test:tribunal-v2": "pnpm exec vitest run tests/tribunal-v2",
    "tribunal:run": "tsx scripts/tribunal-v2-run.ts",
    "tribunal:list": "tsx scripts/tribunal-v2-run.ts --list-in-progress",
    "tribunal:spark-benchmark": "node scripts/spark-tribunal-benchmark.mjs",
    "lint": "eslint middleware.ts src/ scripts/ tests/",
    "lint:fix": "eslint src/ scripts/ tests/ --fix",
    "format": "prettier --write \"src/components/**/*.{astro,js,ts}\" \"src/layouts/**/*.{astro,js,ts}\" \"src/pages/**/*.{astro,js,ts}\" \"src/config/**/*.{js,ts}\" \"src/styles/**/*.css\" \"scripts/**/*.{js,mjs,cjs,ts}\" \"tests/**/*.{js,mjs,cjs,ts}\" \"*.{mjs,cjs,ts}\"",
    "format:check": "prettier --check \"src/components/**/*.{astro,js,ts}\" \"src/layouts/**/*.{astro,js,ts}\" \"src/pages/**/*.{astro,js,ts}\" \"src/config/**/*.{js,ts}\" \"src/styles/**/*.css\" \"scripts/**/*.{js,mjs,cjs,ts}\" \"tests/**/*.{js,mjs,cjs,ts}\" \"*.{mjs,cjs,ts}\"",
    "validate:posts": "node scripts/validate-posts.mjs && node scripts/check-glossary-links.mjs --all",
    "taxonomy:check": "node scripts/check-brand-taxonomy.mjs --check",
    "versions:check": "node scripts/build-version-manifest.mjs --check && node scripts/build-reader-revision-manifest.mjs --check",
    "obsidian:import": "node scripts/obsidian-import.mjs",
    "content:check": "pnpm run validate:posts && pnpm run build",
    "lockfile:check": "pnpm install --frozen-lockfile && git diff --exit-code -- pnpm-lock.yaml",
    "security:gate": "node scripts/security-gate.mjs",
    "spec:ownership": "node scripts/check-spec-ownership.mjs",
    "prepare": "[ -f scripts/setup-hooks.sh ] && scripts/setup-hooks.sh || true",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "lighthouse:collect": "lhci collect --config=lighthouserc.cjs",
    "lighthouse:assert": "lhci assert --config=lighthouserc.cjs",
    "bundle:analyze": "node scripts/bundle-size.mjs",
    "bundle:check": "node scripts/bundle-budget-check.mjs",
    "links:check": "node scripts/check-links.mjs",
    "links:annotate": "node scripts/annotate-broken-links.mjs",
    "deps:check": "node scripts/dependency-freshness.mjs",
    "deps:report": "node scripts/dependency-freshness.mjs --verbose",
    "check:mermaid": "node scripts/check-mermaid-visual.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "content:velocity": "node scripts/content-velocity.mjs",
    "api:dev": "cd sqaa-api && pnpm dev",
    "api:start": "cd sqaa-api && pnpm start",
    "api:test": "cd sqaa-api && pnpm test",
    "glossary:check": "node scripts/check-glossary-links.mjs --all",
    "glossary:check:changed": "node scripts/check-glossary-links.mjs --changed-terms=origin/main --changed-posts=origin/main",
    "glossary:fix": "node scripts/apply-glossary-links.mjs --all",
    "redirects:verify": "node scripts/verify-brand-redirects.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@mdx-js/mdx": "^3.1.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "3.7.5",
    "astro": "^6.4.8",
    "fuse.js": "^7.5.0",
    "hast-util-from-html": "^2.0.3",
    "sharp": "^0.35.3",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "gray-matter": "^4.0.3",
    "monocart-reporter": "^2.12.3",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@10.29.3",
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "tmp": "^0.2.4",
    "fast-xml-builder": "^1.1.7",
    "fast-uri": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "sharp": ">=0.35.0",
      "svgo": ">=4.0.2",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.2",
      "fast-xml-parser": ">=5.5.6",
      "fast-xml-builder": ">=1.1.7",
      "fast-uri": ">=3.1.4 <4",
      "h3": ">=1.15.6",
      "defu": ">=6.1.5",
      "devalue": ">=5.6.4",
      "js-yaml@>=4.0.0 <4.3.0": "4.3.0"
    }
  }
}
