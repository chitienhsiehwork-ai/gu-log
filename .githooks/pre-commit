#!/bin/sh
# Pre-commit hook for gu-log
#
# ALL checks are BLOCKING. Quality over speed.
#
# Pipeline:
#   0) Quick ticketId duplicate check (~100ms, shell)
#   0.1) Score gate for staged zh-tw posts
#   0.15) Pronoun clarity check for staged zh-tw posts
#   0.2) Topic dedup gate for newly added zh-tw posts
#   1) Post validator — frontmatter, content rules, cross-file checks (Node.js)
#   1.5) translatedBy.model consistency check vs runtime model (Node.js)
#   2) Content integrity BDD tests (Playwright, if available)
#   3) Mermaid visual quality check — LLM-as-Judge (if ANTHROPIC_API_KEY set)

set -e
POSTS_DIR="src/content/posts"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED_MDX=$(git diff --cached -M --name-only --diff-filter=ACM -- "$POSTS_DIR"/*.mdx 2>/dev/null || true)

# ─── Step -2: User-wide Markdown zh-tw prose ratio check ───────────
# This repo has its own hooksPath, so it does not inherit the global Git
# hook. Call the shared checker explicitly to keep gu-log aligned with the
# machine-wide Markdown language default.
GLOBAL_MD_ZH_CHECK="$HOME/.config/git/hooks/lib/check-md-zh-tw-ratio.mjs"
if [ -x "$GLOBAL_MD_ZH_CHECK" ]; then
    if command -v node >/dev/null 2>&1; then
        node "$GLOBAL_MD_ZH_CHECK"
    else
        echo "⚠️  node not found, skipping Markdown zh-tw ratio check"
    fi
fi

# ─── Step -1: Gitleaks secret scan (~500ms) ───────────────────────
if command -v gitleaks >/dev/null 2>&1; then
    echo "🔐 Gitleaks: scanning for secrets..."
    if ! gitleaks protect --staged --no-banner 2>&1; then
        echo ""
        echo "❌ SECRETS DETECTED! Do NOT commit."
        echo "   If false positive, add to .gitleaks.toml allowlist."
        exit 1
    fi
    echo "✓ No secrets detected"
    echo ""
else
    echo "⚠️  gitleaks not installed, skipping secret scan"
    echo ""
fi

# ─── Step 0: Quick ticketId duplicate check (shell, ~100ms) ───────
echo "⚡ Quick ticketId duplicate check..."
# PENDING ticketIds are legitimate in-flight placeholders (see
# CONTRIBUTING.md §並行撰寫防 ID collision). Filter them out before
# counting — parallel drafts on the same branch can legitimately share
# "<PREFIX>-PENDING" until the deploy step swaps them for real numbers.
DUPLICATES=$(grep -h 'ticketId:' "$POSTS_DIR"/*.mdx 2>/dev/null | \
    sed 's/.*ticketId:[[:space:]]*["'"'"']\([^"'"'"']*\)["'"'"'].*/\1/' | \
    grep -v -- '-PENDING$' | \
    sort | uniq -c | sort -rn | awk '$1 > 2 {print $2 " (" $1 " occurrences)"}')

if [ -n "$DUPLICATES" ]; then
    echo ""
    echo "❌ DUPLICATE ticketId DETECTED (more than 2 occurrences = not a translation pair):"
    echo "$DUPLICATES"
    echo ""
    echo "Each ticketId should appear exactly 2 times (zh-tw + en version)."
    exit 1
fi
echo "✓ No duplicate ticketIds"
echo ""

# ─── Step 0.1: Score gate — staged posts must clear the score FLOOR ────
# Only checks zh-tw primary posts (not en- translations).
# Minimum: scores.vibe block with persona, clawdNote, vibe, clarity,
# narrative AND composite >= 3 (the FLOOR, not the editorial PASS bar).
#
# Philosophy (2026-06-10): the automated gate is a floor, not the ≥8 PASS
# bar. A post may ship with a sub-8 score — it gets a visible "refining"
# badge and is held out of the homepage until a background tribunal lifts
# it to ≥8 (see CLAUDE.md §自動 gate 是 floor). But nothing garbage
# (composite < 3) or score-less reaches main. The floor check is
# scripts/score-floor-check.mjs.
#
# Scope: enforced on (a) newly ADDED zh-tw posts, and (b) MODIFIED zh-tw
# posts whose READER-VISIBLE content changed (full rewrites). A rewrite is
# a "modification" in git's eyes, so the old added-only gate let rewrites
# slip through unscored (this is how #388 shipped with only 1 of 4 judges).
# reader_visible_changed() compares the staged vs HEAD reader revision so a
# backend-only edit (adding a scores block, fixing source/translatedBy)
# does NOT trigger a rescore — only changes a reader would actually see.
#
# Exemption: posts whose ONLY diff vs HEAD is dedup/series housekeeping
# (status: deprecated, deprecatedReason, deprecatedBy, series.*) skip the
# gate. The score is about content quality, not bookkeeping. Forcing a
# rescore just to add a `series.name` to a 4-month-old post is the wrong
# trade-off.
#
# Merge-commit exemption: if .git/MERGE_HEAD exists we're finalising a
# merge, which brings in content that was already gated on its source
# branch. Re-gating it here would block legitimate merges whenever main
# has posts that didn't pass this specific gate (e.g. pipeline gaps
# where scores were written to scores/tribunal-progress.json instead of
# the mdx frontmatter). Content-quality gates fire on authored commits,
# not on merges.
IS_MERGE_COMMIT=0
if [ -f "$REPO_ROOT/.git/MERGE_HEAD" ]; then
    IS_MERGE_COMMIT=1
fi

if [ "$IS_MERGE_COMMIT" = "1" ]; then
    echo "📊 Score gate: merge commit detected — skipping (content was gated on source branches)"
else
    echo "📊 Score gate: checking staged posts against score floor (composite >= 3)..."
fi
SCORE_MISSING=""
# Newly ADDED zh-tw posts always go through the gate.
STAGED_ZH_POSTS=$(git diff --cached -M --name-only --diff-filter=A -- "$POSTS_DIR"/*.mdx 2>/dev/null | grep -v '/en-' | sed '/^$/d' || true)
# MODIFIED zh-tw posts go through the gate too, but only when their
# reader-visible content changed (full rewrites) — see reader_visible_changed.
STAGED_ZH_MODIFIED=$(git diff --cached -M --name-only --diff-filter=M -- "$POSTS_DIR"/*.mdx 2>/dev/null | grep -v '/en-' | sed '/^$/d' || true)

# reader_visible_changed FILE → 0 (true) when the staged version's reader-facing
# content (reader-visible frontmatter + body) differs from HEAD's. Backend-only
# frontmatter (scores, translatedBy, pipeline, …) is excluded by the shared
# hash, so adding a scores block alone is NOT a reader-visible change.
reader_visible_changed() {
    local file="$1"
    # No HEAD version → brand-new content → treat as changed.
    if ! git cat-file -e "HEAD:$file" 2>/dev/null; then
        return 0
    fi
    local head_rev staged_rev
    head_rev=$(git show "HEAD:$file" 2>/dev/null | node "$REPO_ROOT/scripts/reader-revision-of-stdin.mjs" 2>/dev/null || echo "ERR")
    staged_rev=$(git show ":$file" 2>/dev/null | node "$REPO_ROOT/scripts/reader-revision-of-stdin.mjs" 2>/dev/null || echo "ERR")
    # On any compute error, fail safe → gate it.
    if [ "$head_rev" = "ERR" ] || [ "$staged_rev" = "ERR" ]; then
        return 0
    fi
    [ "$head_rev" != "$staged_rev" ]
}

is_metadata_only_diff() {
    local file="$1"
    # If the file is newly added there's no HEAD version to diff against —
    # treat as content change so the gate enforces.
    if ! git cat-file -e "HEAD:$file" 2>/dev/null; then
        return 1
    fi
    # All added/removed lines (excluding the ±±± headers) must match the
    # housekeeping field allowlist. Anything else → content change.
    local diff_body
    diff_body=$(git diff --cached --no-color -U0 -- "$file" \
        | grep -E '^[+-]' \
        | grep -vE '^(\+\+\+|---) ' \
        || true)
    if [ -z "$diff_body" ]; then
        return 0
    fi
    if printf '%s\n' "$diff_body" \
        | grep -vqE '^[+-][[:space:]]*(status|deprecatedReason|deprecatedBy|series|name|order):'; then
        return 1
    fi
    return 0
}

is_internal_post_link_only_diff() {
    local file="$1"
    # Link maintenance should not re-lint grandfathered article prose.
    # Normalize added/removed lines by stripping internal Markdown links; if the
    # underlying text is identical, this is maintenance-only.
    if ! git cat-file -e "HEAD:$file" 2>/dev/null; then
        return 1
    fi

    git diff --cached --no-color -U0 -- "$file" | python3 -c '
import re, sys
lines = []
for line in sys.stdin:
    if not (line.startswith("+") or line.startswith("-")):
        continue
    if line.startswith("+++ ") or line.startswith("--- "):
        continue
    lines.append(line.rstrip("\n"))
if not lines:
    sys.exit(0)
def norm(line):
    text = line[1:]
    text = re.sub(r"\[([^\]\n]+)\]\(/(?:en/)?glossary#[^)\n]+\)", r"\1", text)
    text = re.sub(r"\[([^\]\n]+)\]\(/posts/[^)\n]+\)", r"\1", text)
    text = re.sub(r"\[([^\]\n]+)\]\(/en/posts/[^)\n]+\)", r"\1", text)
    return text.strip()
removed = sorted(norm(line) for line in lines if line.startswith("-"))
added = sorted(norm(line) for line in lines if line.startswith("+"))
sys.exit(0 if removed == added else 1)
'
}

is_existing_ticket_post_addition() {
    local file="$1"
    local full_path="$REPO_ROOT/$file"
    local ticket
    local existing_paths

    # Git can report rename destinations as added in some staged bulk
    # migrations. If the ticketId already exists in HEAD, this is legacy
    # content moving paths, not a new article entering the quality funnel.
    if git cat-file -e "HEAD:$file" 2>/dev/null; then
        return 1
    fi
    if [ ! -f "$full_path" ]; then
        return 1
    fi

    ticket=$(sed -n 's/^ticketId:[[:space:]]*["'"'"']\([^"'"'"']*\)["'"'"'].*/\1/p' "$full_path" | head -1)
    if [ -z "$ticket" ]; then
        return 1
    fi
    case "$ticket" in
        *-PENDING) return 1 ;;
    esac

    existing_paths=$(git grep -l -E "^ticketId:[[:space:]]*[\"']${ticket}[\"']" HEAD -- "$POSTS_DIR/*.mdx" 2>/dev/null || true)
    if [ -z "$existing_paths" ]; then
        return 1
    fi
    printf '%s\n' "$existing_paths" | grep -vx "$file" >/dev/null 2>&1
}

GATE_CANDIDATES=$(printf '%s\n%s\n' "$STAGED_ZH_POSTS" "$STAGED_ZH_MODIFIED" | sed '/^$/d' | sort -u)

if [ -z "$GATE_CANDIDATES" ]; then
    echo "✓ No zh-tw posts staged"
elif [ "$IS_MERGE_COMMIT" = "1" ]; then
    : # already printed the skip message above
else
    for file in $GATE_CANDIDATES; do
        FULL_PATH="$REPO_ROOT/$file"
        if [ ! -f "$FULL_PATH" ]; then continue; fi

        # Modifications: only gate when reader-visible content changed (full
        # rewrites). Added files have no HEAD version and always gate.
        if git cat-file -e "HEAD:$file" 2>/dev/null; then
            if ! reader_visible_changed "$file"; then
                continue
            fi
        fi

        # Skip the gate if this is a metadata-only housekeeping edit.
        if is_metadata_only_diff "$file"; then
            continue
        fi

        # Skip internal-link maintenance (glossary / cross-ref links) — same
        # exemption the pronoun check uses, so adding /glossary# links to a
        # grandfathered post doesn't force a rescore.
        if is_internal_post_link_only_diff "$file"; then
            continue
        fi

        if is_existing_ticket_post_addition "$file"; then
            continue
        fi

        # Skip the gate for PENDING drafts — scoring happens during tribunal
        # between draft and deploy. See CONTRIBUTING.md §並行撰寫防 ID collision.
        # The pre-push guard ensures PENDING never reaches main anyway.
        if grep -qE '^ticketId:[[:space:]]*["'"'"'][A-Za-z]+-PENDING["'"'"']' "$FULL_PATH" 2>/dev/null; then
            continue
        fi

        # Floor gate: scores.vibe present + complete (5 dims) + composite >= 3.
        # Sub-8 is allowed (badged + held off the homepage); garbage (<3) and
        # score-less posts are blocked. See scripts/score-floor-check.mjs.
        if ! FLOOR_MSG=$(node "$REPO_ROOT/scripts/score-floor-check.mjs" "$FULL_PATH" 3 2>&1); then
            BASENAME=$(basename "$file")
            SCORE_MISSING="$SCORE_MISSING  ⚠️  $BASENAME — ${FLOOR_MSG}\n"
        fi
    done
fi

if [ -n "$SCORE_MISSING" ]; then
    echo ""
    echo "❌ SCORE GATE FAILED — staged zh-tw posts below the score floor:"
    printf "$SCORE_MISSING"
    echo ""
    echo "Every new or rewritten zh-tw post needs a scores.vibe block with"
    echo "composite >= 3 (the floor — NOT the ≥8 PASS bar; sub-8 may ship but"
    echo "gets a 'refining' badge and is held off the homepage). Run the"
    echo "tribunal, or score manually with:"
    echo "  node scripts/frontmatter-scores.mjs write <file> vibe '<json>'"
    echo ""
    echo "To bypass in emergency: git commit --no-verify"
    exit 1
fi
echo "✓ All staged zh-tw posts clear the score floor (composite >= 3)"
echo ""

# ─── Step 0.15: Pronoun clarity check (你/我 ban in zh-tw body) ───
# Same metadata-only exemption as the score gate: housekeeping edits
# (status/series/deprecation) don't change body text and shouldn't be
# punished for pre-existing 你/我 in 4-month-old articles.
# Also skipped on merge commits — content was gated on source branches.
if [ -n "$STAGED_MDX" ] && [ "$IS_MERGE_COMMIT" != "1" ]; then
    ZH_FILES=""
    for file in $STAGED_MDX; do
        case "$file" in
            */en-*) ;; # skip English
            *)
                if is_metadata_only_diff "$file"; then
                    continue
                fi
                if is_internal_post_link_only_diff "$file"; then
                    continue
                fi
                if is_existing_ticket_post_addition "$file"; then
                    continue
                fi
                ZH_FILES="$ZH_FILES $REPO_ROOT/$file"
                ;;
        esac
    done

    if [ -n "$ZH_FILES" ]; then
        echo "🔍 Pronoun clarity: checking zh-tw posts for 你/我 in body..."
        if ! node "$REPO_ROOT/scripts/check-pronoun-clarity.mjs" $ZH_FILES; then
            echo ""
            echo "❌ Pronoun clarity check FAILED."
            echo "   你/我 found in article body (outside ClawdNote/blockquote/code)."
            echo "   Use specific names (ShroomDog, Clawd, 讀者) or restructure sentences."
            exit 1
        fi
        echo "✓ Pronoun clarity passed"

        # ─── Step 0.16: 晶晶體 check (zh-tw decorative English mixing) ───
        # Per GU-LOG_WRITER_PROMPT.md §術語處理, zh-tw posts must not mix
        # decorative English. The English allowlist is src/data/glossary.json
        # plus a hardcoded list of proper nouns / acronyms in the lint script.
        # Same staged-only + metadata-exemption + merge-skip pattern as the
        # pronoun check above — historical articles have grandfathered 晶晶體
        # but new commits and edits to zh-tw bodies must be clean.
        echo "🈳 晶晶體 check: scanning staged zh-tw posts for decorative English..."
        if ! node "$REPO_ROOT/scripts/check-jingjing.mjs" $ZH_FILES; then
            echo ""
            echo "❌ 晶晶體 check FAILED."
            echo "   Translate to natural zh-tw OR add to src/data/glossary.json"
            echo "   OR (if proper noun) add to ALLOWLIST_RAW in scripts/check-jingjing.mjs."
            exit 1
        fi
        echo "✓ 晶晶體 check passed"
    fi
elif [ "$IS_MERGE_COMMIT" = "1" ]; then
    echo "🔍 Pronoun clarity: merge commit detected — skipping"
    echo "🈳 晶晶體 check: merge commit detected — skipping"
fi

# ─── Step 0.17: Glossary link coverage ratchet ─────────────────────
# Phase 1 pre-commit gate: changed posts must link enabled glossary terms,
# and changed glossary entries must be backfilled across existing posts.
STAGED_GLOSSARY=$(git diff --cached --name-only --diff-filter=ACM -- src/data/glossary.json 2>/dev/null || true)
if [ "$IS_MERGE_COMMIT" != "1" ]; then
    if [ -n "$STAGED_MDX" ] || [ -n "$STAGED_GLOSSARY" ]; then
        echo "🔗 Glossary links: checking staged post/glossary coverage..."
        GLOSSARY_ARGS=""
        if [ -n "$STAGED_MDX" ]; then
            GLOSSARY_ARGS="$GLOSSARY_ARGS --files \"$STAGED_MDX\""
        fi
        if [ -n "$STAGED_GLOSSARY" ]; then
            GLOSSARY_ARGS="$GLOSSARY_ARGS --changed-terms=HEAD"
        fi
        # shellcheck disable=SC2086
        if ! eval node "$REPO_ROOT/scripts/check-glossary-links.mjs" $GLOSSARY_ARGS; then
            echo ""
            echo "❌ Glossary link coverage FAILED."
            echo "   Run: node scripts/apply-glossary-links.mjs --all"
            echo "   Or:  node scripts/apply-glossary-links.mjs --term <Term> <post.mdx>"
            exit 1
        fi
        echo "✓ Glossary link coverage passed"
    fi
else
    echo "🔗 Glossary links: merge commit detected — skipping"
fi
echo ""

# ─── Step 0.2: Topic dedup gate for newly added zh-tw posts ──────
echo "🧠 Topic dedup gate: checking newly added zh-tw posts..."
ADDED_ZH_POSTS=$(git diff --cached -M --name-only --diff-filter=A -- "$POSTS_DIR"/*.mdx 2>/dev/null | grep -v '/en-' || true)

if [ -z "$ADDED_ZH_POSTS" ]; then
    echo "✓ No newly added zh-tw posts"
else
    for file in $ADDED_ZH_POSTS; do
        FULL_PATH="$REPO_ROOT/$file"
        if [ ! -f "$FULL_PATH" ]; then
            continue
        fi

        if is_existing_ticket_post_addition "$file"; then
            continue
        fi

        TITLE=$(grep '^title:' "$FULL_PATH" 2>/dev/null | head -1 | sed 's/title: *"\?//;s/"\?$//' || true)
        SOURCE_URL=$(grep '^sourceUrl:' "$FULL_PATH" 2>/dev/null | head -1 | sed 's/sourceUrl: *"\?//;s/"\?$//' || true)
        TAGS=$(grep '^tags:' "$FULL_PATH" 2>/dev/null | head -1 | sed 's/tags: *\[//;s/\]$//;s/["'"'"']//g;s/, */,/g' || true)

        if [ -z "$TITLE" ] || [ -z "$SOURCE_URL" ]; then
            echo "⚠️  Skipping topic dedup for $(basename "$file") — missing title or sourceUrl"
            continue
        fi

        RESULT=$(node "$REPO_ROOT/scripts/topic-dedup-check.mjs" \
            --url "$SOURCE_URL" \
            --title "$TITLE" \
            --tags "$TAGS" \
            --ignore-file "$FULL_PATH")

        STATUS=$(printf '%s' "$RESULT" | node -e "let data='';process.stdin.on('data',c=>data+=c);process.stdin.on('end',()=>console.log(JSON.parse(data).status));")
        SCORE=$(printf '%s' "$RESULT" | node -e "let data='';process.stdin.on('data',c=>data+=c);process.stdin.on('end',()=>console.log(JSON.parse(data).score));")
        MATCH=$(printf '%s' "$RESULT" | node -e "let data='';process.stdin.on('data',c=>data+=c);process.stdin.on('end',()=>{const parsed=JSON.parse(data); console.log(parsed.match ? parsed.match.ticketId + ' — ' + parsed.match.title : 'none');});")

        if [ "$STATUS" = "BLOCK" ]; then
            echo ""
            echo "❌ TOPIC DEDUP BLOCKED: $(basename "$file")"
            echo "   Score: $SCORE"
            echo "   Match: $MATCH"
            echo "   Full result:"
            printf '%s\n' "$RESULT"
            echo ""
            echo "This looks like a duplicate topic. Use a different source/topic, or bypass with --no-verify if intentional."
            exit 1
        fi

        if [ "$STATUS" = "WARN" ]; then
            echo "⚠️  Topic dedup warning for $(basename "$file"): $MATCH (score=$SCORE)"
        fi
    done
fi
echo ""

content_gate_mdx_files() {
    local files=""
    local file
    for file in $STAGED_MDX; do
        if is_internal_post_link_only_diff "$file"; then
            continue
        fi
        if is_existing_ticket_post_addition "$file"; then
            continue
        fi
        files="$files $file"
    done
    printf '%s\n' "$files" | sed 's/^ *//;s/ *$//'
}

CONTENT_GATE_MDX=$(content_gate_mdx_files)

# ─── Step 0.45: WCAG AA contrast check on staged components ──────
STAGED_STYLE=$(git diff --cached --name-only --diff-filter=ACM -- 'src/components/*.astro' 'src/styles/*.css' 2>/dev/null || true)

if [ -z "$STAGED_STYLE" ]; then
    echo "✓ No component/style files staged — skipping contrast check"
else
    STYLE_COUNT=$(echo "$STAGED_STYLE" | wc -l | tr -d ' ')
    echo "🎨 Contrast check: $STYLE_COUNT staged component/style file(s)..."

    STYLE_FILES=""
    for file in $STAGED_STYLE; do
        if [ -f "$REPO_ROOT/$file" ]; then
            STYLE_FILES="$STYLE_FILES $REPO_ROOT/$file"
        fi
    done

    if [ -n "$STYLE_FILES" ]; then
        if ! node "$REPO_ROOT/scripts/check-contrast.mjs" $STYLE_FILES; then
            echo ""
            echo "❌ WCAG AA contrast check FAILED."
            echo "   Fix color pairs to meet ≥4.5:1 contrast ratio."
            echo "   Run: pnpm run check:contrast"
            exit 1
        fi
        echo "✓ Contrast check passed"
    fi
fi
echo ""

# ─── Step 0.5: ESLint check on staged files ──────────────────────
STAGED_LINT=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' '*.astro' '*.mjs' 2>/dev/null || true)

if [ -z "$STAGED_LINT" ]; then
    echo "✓ No lintable files staged"
else
    LINT_COUNT=$(echo "$STAGED_LINT" | wc -l | tr -d ' ')
    echo "🔍 ESLint: checking $LINT_COUNT staged file(s)..."

    LINT_FILES=""
    for file in $STAGED_LINT; do
        if [ -f "$REPO_ROOT/$file" ]; then
            LINT_FILES="$LINT_FILES $REPO_ROOT/$file"
        fi
    done

    if [ -n "$LINT_FILES" ]; then
        # --max-warnings=-1 means unlimited warnings; we only block on errors
        if ! npx eslint --no-warn-ignored $LINT_FILES 2>&1; then
            LINT_EXIT=$?
            # eslint exit code 1 = lint errors found
            if [ "$LINT_EXIT" -eq 1 ]; then
                echo ""
                echo "❌ ESLint found errors. Fix them before committing."
                echo "   Run: pnpm run lint:fix"
                exit 1
            fi
        fi
        echo "✓ ESLint passed"
    fi
fi
echo ""

# ─── Step 0.6: Prettier format check (full codebase) ─────────────
echo "🎨 Prettier: checking all source files..."
if ! npx prettier --check \
    "src/components/**/*.{astro,js,ts}" \
    "src/layouts/**/*.{astro,js,ts}" \
    "src/pages/**/*.{astro,js,ts}" \
    "src/config/**/*.{js,ts}" \
    "src/styles/**/*.css" \
    "scripts/**/*.{js,mjs,cjs,ts}" \
    "*.{mjs,cjs,ts}" 2>&1; then
    echo ""
    echo "❌ Prettier found formatting issues. Fix them before committing."
    echo "   Run: pnpm run format"
    exit 1
fi
echo "✓ Prettier passed"
echo ""

# ─── Step 1: Post validator (Node.js, blocking) ──────────────────
# Validate only staged .mdx files that changed content. Legacy filename
# migrations and internal link rewrites are verified separately by full
# validation/link checks, but should not resurrect grandfathered body rules.
if [ -z "$CONTENT_GATE_MDX" ]; then
    echo "✓ No .mdx files to validate"
else
    FILE_COUNT=$(echo "$CONTENT_GATE_MDX" | wc -l | tr -d ' ')
    echo "🔍 Validating $FILE_COUNT staged .mdx file(s)..."

    # Build file list as arguments
    FILE_ARGS=""
    for file in $CONTENT_GATE_MDX; do
        FILE_ARGS="$FILE_ARGS $REPO_ROOT/$file"
    done

    if ! node "$REPO_ROOT/scripts/validate-posts.mjs" $FILE_ARGS; then
        echo ""
        echo "❌ Post validation FAILED. Fix errors above before committing."
        exit 1
    fi
fi
echo ""

# ─── Step 1.5: translatedBy.model runtime consistency (blocking) ─
if [ -n "$CONTENT_GATE_MDX" ]; then
    FILE_ARGS=""
    for file in $CONTENT_GATE_MDX; do
        FILE_ARGS="$FILE_ARGS $REPO_ROOT/$file"
    done

    if ! node "$REPO_ROOT/scripts/check-translatedby-model.mjs" $FILE_ARGS; then
        echo ""
        echo "❌ translatedBy.model consistency check FAILED."
        echo "   Fix frontmatter model names or ensure OPENCLAW_MODEL mapping is correct."
        exit 1
    fi
fi
echo ""

# ─── Step 2: Content integrity BDD tests (Playwright) ────────────
# Only run when posts/*.mdx are staged (tests validate post content integrity)
if [ -f "$REPO_ROOT/tests/content-integrity.spec.ts" ] && [ -n "$STAGED_MDX" ]; then
    echo "🧪 Running content integrity tests..."
    if ! PLAYWRIGHT_BASE_URL=https://gu-log.vercel.app npx playwright test tests/content-integrity.spec.ts --project='Desktop Chrome' --reporter=line 2>&1; then
        echo ""
        echo "❌ Content integrity tests FAILED."
        exit 1
    fi
    echo "✓ Content integrity tests passed"
    echo ""
fi

# ─── Step 3: Mermaid visual quality check (LLM-as-Judge) ─────────
# Only runs if ANTHROPIC_API_KEY is set and staged .mdx files contain Mermaid
if [ -n "$ANTHROPIC_API_KEY" ]; then
    # Find staged .mdx files that contain <Mermaid
    MERMAID_FILES=""
    if [ -n "$STAGED_MDX" ]; then
        for file in $STAGED_MDX; do
            if [ -f "$REPO_ROOT/$file" ] && grep -q '<Mermaid' "$REPO_ROOT/$file" 2>/dev/null; then
                MERMAID_FILES="$MERMAID_FILES $REPO_ROOT/$file"
            fi
        done
    fi

    if [ -z "$MERMAID_FILES" ]; then
        echo "✓ No Mermaid diagrams in staged files"
    else
        MERMAID_COUNT=$(echo "$MERMAID_FILES" | wc -w | tr -d ' ')
        echo "📐 Mermaid visual check: $MERMAID_COUNT file(s) with diagrams..."

        if ! node "$REPO_ROOT/scripts/check-mermaid-visual.mjs" --files $MERMAID_FILES; then
            echo ""
            echo "❌ Mermaid visual quality check FAILED."
            echo "   Some diagrams are not readable on mobile (iPhone 14, 390px)."
            echo "   Run 'pnpm run check:mermaid' for a full report with screenshots."
            exit 1
        fi
        echo "✓ Mermaid visual check passed"
    fi
    echo ""
else
    echo "ℹ️  Skipping Mermaid visual check (ANTHROPIC_API_KEY not set)"
    echo ""
fi

echo "✓ All pre-commit checks passed!"
exit 0
