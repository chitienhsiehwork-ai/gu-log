#!/bin/bash
echo "🚀 Running pre-push checks..."

# 0. PENDING ticketId guard — never push a PENDING placeholder to main.
#    PENDING is a legitimate in-flight state on working branches (see
#    CONTRIBUTING.md §並行撰寫防 ID collision), but must be swapped for
#    a real ticket number before merging to main. Prod MDX with
#    ticketId "MP-PENDING" would render on gu-log.vercel.app.
#
#    Git stdin contract for pre-push: <local-ref> <local-sha> <remote-ref> <remote-sha>
#    per line. If any line targets refs/heads/main and the commits being
#    pushed touch a posts/*.mdx with "-PENDING" ticketId, block.
while read -r _local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      # local_sha of all-zeros = branch delete, skip.
      if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
      fi
      # For a brand-new remote branch, remote_sha is all-zeros and there is
      # no remote tree to diff against. Scan the complete local_sha tree:
      # every post in that commit is about to become remote content.
      if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        if ! CANDIDATE_FILES=$(git ls-tree -r --name-only "$local_sha" -- src/content/posts 2>/dev/null); then
          echo "❌ Cannot inspect committed posts at $local_sha; blocking push to $remote_ref."
          exit 1
        fi
      else
        if ! CANDIDATE_FILES=$(git diff -M --name-only --diff-filter=AMR "${remote_sha}..${local_sha}" -- 'src/content/posts/*.mdx' 2>/dev/null); then
          echo "❌ Cannot diff committed posts at ${remote_sha}..${local_sha}; blocking push to $remote_ref."
          exit 1
        fi
      fi

      # Inspect blobs from local_sha, never the mutable working tree. Otherwise
      # an uncommitted edit that replaces PENDING with a real number could hide
      # the PENDING value in the commit that is actually being pushed.
      PENDING_FILES=""
      while IFS= read -r file; do
        [ -z "$file" ] && continue
        case "$file" in
          *.mdx) ;;
          *) continue ;;
        esac
        if git grep -q 'ticketId:.*-PENDING' "$local_sha" -- "$file" 2>/dev/null; then
          PENDING_FILES="${PENDING_FILES}${file}
"
        else
          GREP_STATUS=$?
          if [ "$GREP_STATUS" -gt 1 ]; then
            echo "❌ Cannot inspect committed blob ${local_sha}:${file}; blocking push to $remote_ref."
            exit 1
          fi
        fi
      done <<EOF
$CANDIDATE_FILES
EOF
      if [ -n "$PENDING_FILES" ]; then
        echo ""
        echo "❌ PENDING ticketId in commits being pushed to $remote_ref:"
        printf '%s' "$PENDING_FILES" | sed 's/^/   /'
        echo ""
        echo "   Swap PENDING for a real ticket number before pushing to main."
        echo "   See CONTRIBUTING.md §並行撰寫防 ID collision for the swap procedure."
        exit 1
      fi
      ;;
  esac
done

# 1. Retired brand contracts are a merge blocker. Exact historical and
#    fail-closed-test exceptions live in the scanner policy; everything else
#    must use the canonical Mogu / GP / MP taxonomy before a branch is pushed.
echo "🏷️  Checking retired brand taxonomy contracts..."
if ! pnpm run taxonomy:check; then
  echo ""
  echo "❌ Retired brand taxonomy residuals remain. Push aborted."
  exit 1
fi

# 2. Post version manifest freshness — Vercel production uses the committed
#    manifest on shallow clones, so content-touching commits must keep it fresh.
#    CCC/local clones are frequently shallow, and build-version-manifest.mjs
#    deliberately skips (exit 0) on a shallow clone because it can't count
#    history it doesn't have. That made this very check a no-op in CCC sessions:
#    a stale manifest sailed past pre-push and only blew up in CI's unit-tests,
#    costing a full remote round-trip. Fix: if we're shallow, deepen first
#    (safe — pre-push never runs on Vercel), so the check actually runs; and if
#    it's stale, regenerate the file in place so the agent just has to commit it.
echo "🔢 Checking post version manifest freshness..."
if [ "$(git rev-parse --is-shallow-repository 2>/dev/null)" = "true" ]; then
  echo "   Shallow clone — fetching full history so the manifest check is meaningful..."
  git fetch --unshallow --quiet origin 2>/dev/null \
    || git fetch --depth=2147483647 --quiet origin 2>/dev/null \
    || true
fi
if ! node scripts/build-version-manifest.mjs --check; then
  echo "   Stale manifest — regenerating src/data/post-versions.json for you..."
  node scripts/build-version-manifest.mjs
  echo ""
  echo "❌ post-versions.json was stale (now regenerated). Push aborted."
  echo "   Commit the updated src/data/post-versions.json, then push again."
  echo "   (The visible vN badge must match git history; Vercel serves the committed manifest.)"
  exit 1
fi

# 3. Bundle budget check (LOCAL = warning-only; CI is the blocking authority)
#    Local dist can be stale/incremental, which inflates the aggregate JS+CSS
#    sum and produces false blocks. The CI `bundle-budget` job runs the same
#    check against a clean build artifact and IS allowed to fail the PR (see #396).
#    Do NOT re-add `exit 1` here — that reintroduces the false-block that forced
#    --no-verify on every push.
echo "📦 Checking bundle budgets (local: warning-only; CI enforces on a clean build)..."
if ! node scripts/bundle-budget-check.mjs; then
  echo "⚠️  Local bundle budget check flagged a violation — NOT blocking the push."
  echo "   Likely a stale/incremental dist false positive. CI checks a clean build."
  echo "   If CI's bundle-budget job also fails, shrink the bundle or rebaseline"
  echo "   quality/bundle-budget.json."
fi

# 4. Coverage ratchet (only if tests can run quickly)
# Skip for now - tests take too long for pre-push
# echo "🧪 Checking test coverage ratchet..."
# bash scripts/coverage-ratchet.sh

echo "✅ Pre-push checks passed!"
